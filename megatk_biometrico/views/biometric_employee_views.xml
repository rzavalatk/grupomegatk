<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_biometric_employee_tree" model="ir.ui.view">
        <field name="name">biometric.employee.tree</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <tree string="Empleados Biométricos">
                <field name="enroll_id"/>
                <field name="name"/>
                <field name="biometric_person_name"/>
                <field name="biometric_on_device" widget="boolean_toggle"/>
                <field name="work_email"/>
            </tree>
        </field>
    </record>

    <record id="view_biometric_employee_form" model="ir.ui.view">
        <field name="name">biometric.employee.form</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <form string="Empleado" create="false">
                <sheet>
                    <group>
                        <field name="enroll_id"/>
                        <field name="biometric_person_name" readonly="1"/>
                        <field name="biometric_on_device" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biometric_employees" model="ir.actions.act_window">
        <field name="name">Empleados Biométricos</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[(ref('view_biometric_employee_tree'), 'list'), (ref('view_biometric_employee_form'), 'form')]"/>
        <field name="domain">[('enroll_id', '!=', False)]</field>
    </record>
</odoo>

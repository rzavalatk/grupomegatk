<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_biometric_record_tree" model="ir.ui.view">
        <field name="name">biometric.record.tree</field>
        <field name="model">biometric.record</field>
        <field name="arch" type="xml">
            <list string="Marcaciones">
                <field name="records_time_raw"/>
                <field name="inout"/>
                <field name="event"/>
                <field name="temperature"/>
            </list>
        </field>
    </record>

    <record id="view_biometric_record_form" model="ir.ui.view">
        <field name="name">biometric.record.form</field>
        <field name="model">biometric.record</field>
        <field name="arch" type="xml">
            <form string="Marcación Biométrica">
                <header>
                    <button name="action_sync_records" type="object" string="Sincronizar" class="btn btn-primary" icon="fa-refresh"/>
                </header>
                <sheet>
                    <group>
                        <field name="records_time_raw" readonly="1"/>
                        <field name="records_time" readonly="1"/>
                        <field name="employee_name" readonly="1"/>
                    </group>
                    <group>
                        <field name="device_serial_num"/>
                        <field name="device_id" readonly="1"/>
                        <field name="enroll_id"/>
                        <field name="employee_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="mode"/>
                        <field name="inout"/>
                        <field name="event"/>
                        <field name="temperature"/>
                    </group>
                    <group>
                        <field name="image"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biometric_record" model="ir.actions.act_window">
        <field name="name">Marcaciones</field>
        <field name="res_model">biometric.record</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_biometric_record_tree"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Revisa y descarga todos los registros de marcación biométrica.
                Presiona el botón "Sincronizar" para obtener nuevas marcaciones del servidor.
            </p>
        </field>
    </record>

    <!-- Acción de menú para sincronizar registros -->
    <record id="action_sync_records_button" model="ir.actions.server">
        <field name="name">Sincronizar Marcaciones</field>
        <field name="model_id" ref="model_biometric_record"/>
        <field name="state">code</field>
        <field name="code">result = model.action_sync_records()</field>
    </record>
</odoo>

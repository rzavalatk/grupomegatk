<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_employee_form_biometric" model="ir.ui.view">
        <field name="name">hr.employee.form.biometric</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="inside">
                <group string="Datos Biométricos" name="biometric_section">
                    <field name="enroll_id" help="ID de inscripción en el dispositivo biométrico para vincular marcaciones"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

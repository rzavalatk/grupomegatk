<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_biometric_settings_tree" model="ir.ui.view">
        <field name="name">biometric.config.list</field>
        <field name="model">biometric.config</field>
        <field name="arch" type="xml">
            <list string="Ajustes Biométricos">
                <field name="company_id"/>
                <field name="server_url"/>
                <field name="api_token"/>
                <field name="websocket_url"/>
                <field name="default_device_group"/>
                <field name="allow_command_execution"/>
            </list>
        </field>
    </record>

    <record id="view_biometric_settings_form" model="ir.ui.view">
        <field name="name">biometric.config.form</field>
        <field name="model">biometric.config</field>
        <field name="arch" type="xml">
            <form string="Ajustes Biométricos">
                <sheet>
                    <group>
                        <field name="company_id"/>
                        <field name="server_url"/>
                        <field name="api_token"/>
                        <field name="websocket_url"/>
                        <field name="default_device_group"/>
                        <field name="allow_command_execution"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biometric_settings" model="ir.actions.act_window">
        <field name="name">Ajustes Biométricos</field>
        <field name="res_model">biometric.config</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_biometric_settings_tree"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Configura la conexión a los dispositivos biométricos por compañía.
            </p>
        </field>
    </record>
</odoo>

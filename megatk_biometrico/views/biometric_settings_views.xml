<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_biometric_settings_tree" model="ir.ui.view">
        <field name="name">biometric.config.list</field>
        <field name="model">biometric.config</field>
        <field name="arch" type="xml">
            <list string="Ajustes Biométricos" create="true">
                <field name="company_id"/>
                <field name="server_url"/>
                <field name="api_token"/>
                <field name="websocket_url"/>
                <field name="default_device_group"/>
                <field name="allow_command_execution"/>
            </list>
        </field>
    </record>

    <record id="view_biometric_settings_form" model="ir.ui.view">
        <field name="name">biometric.config.form</field>
        <field name="model">biometric.config</field>
        <field name="arch" type="xml">
            <form string="Ajustes Biométricos">
                <header>
                    <button name="sync_devices" type="object" string="Sincronizar Dispositivos" class="btn btn-primary" icon="fa-refresh"/>
                    <button name="sync_records" type="object" string="Sincronizar Marcaciones" class="btn btn-primary" icon="fa-refresh"/>
                </header>
                <sheet>
                    <group>
                        <field name="company_id"/>
                        <field name="server_url" placeholder="http://13.58.64.227:7792"/>
                        <field name="api_token" placeholder="Token opcional para autenticación"/>
                        <field name="websocket_url" placeholder="ws://13.58.64.227:7792/pub/chat"/>
                        <field name="default_device_group"/>
                        <field name="allow_command_execution"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biometric_settings" model="ir.actions.act_window">
        <field name="name">Ajustes Biométricos</field>
        <field name="res_model">biometric.config</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[(ref('view_biometric_settings_tree'), 'list'), (ref('view_biometric_settings_form'), 'form')]"/>
        <field name="target">current</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Configura la conexión a los dispositivos biométricos por compañía.
            </p>
        </field>
    </record>
</odoo>

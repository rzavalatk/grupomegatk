<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_biometric_command_tree" model="ir.ui.view">
        <field name="name">biometric.command.tree</field>
        <field name="model">biometric.command</field>
        <field name="arch" type="xml">
            <list string="Comandos Biométricos">
                <field name="serial"/>
                <field name="command_type"/>
                <field name="person_id"/>
                <field name="name"/>
                <field name="status" widget="badge" decoration-success="status=='2'" decoration-warning="status=='0'" decoration-info="status=='1'" decoration-danger="status=='3'"/>
                <field name="send_status"/>
                <field name="created_at"/>
            </list>
        </field>
    </record>

    <record id="view_biometric_command_form" model="ir.ui.view">
        <field name="name">biometric.command.form</field>
        <field name="model">biometric.command</field>
        <field name="arch" type="xml">
            <form string="Comando Biométrico">
                <header>
                    <button name="execute_command" type="object" string="Ejecutar Comando" class="btn btn-primary" states="0" icon="fa-send"/>
                    <button name="%(action_sync_devices_server)d" type="action" string="Refrescar Dispositivos" icon="fa-refresh"/>
                </header>
                <sheet>
                    <group>
                        <field name="serial"/>
                        <field name="device_id" readonly="1"/>
                        <field name="command_type" widget="radio" options="{'horizontal': true}"/>
                    </group>
                    <group>
                        <field name="person_id" attrs="{'required': [('command_type', '!=', 'getuserlist')], 'invisible': [('command_type', '=', 'getuserlist')]}"/>
                    </group>
                    <group>
                        <field name="status" widget="badge" decoration-success="status=='2'" decoration-warning="status=='0'" decoration-info="status=='1'" decoration-danger="status=='3'"/>
                        <field name="send_status"/>
                        <field name="err_count"/>
                        <field name="created_at" readonly="1"/>
                        <field name="run_time" readonly="1"/>
                    </group>
                    <group string="Contenido del Comando">
                        <field name="name" readonly="1"/>
                        <field name="content" widget="text" readonly="1"/>
                    </group>
                    <group string="Resultado" attrs="{'invisible': [('message', '=', False)]}">
                        <field name="message" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biometric_command" model="ir.actions.act_window">
        <field name="name">Comandos</field>
        <field name="res_model">biometric.command</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_biometric_command_tree"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Administra comandos y envíalos a los dispositivos biométricos.
                Selecciona un dispositivo, elige el tipo de comando y presiona "Ejecutar Comando".
            </p>
        </field>
    </record>

    <!-- Vistas para modelo biometric.person -->
    <record id="view_biometric_person_tree" model="ir.ui.view">
        <field name="name">biometric.person.tree</field>
        <field name="model">biometric.person</field>
        <field name="arch" type="xml">
            <list string="Usuarios Biométricos">
                <field name="enroll_id"/>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="created_at"/>
            </list>
        </field>
    </record>

    <record id="view_biometric_person_form" model="ir.ui.view">
        <field name="name">biometric.person.form</field>
        <field name="model">biometric.person</field>
        <field name="arch" type="xml">
            <form string="Usuario Biométrico">
                <sheet>
                    <group>
                        <field name="enroll_id"/>
                        <field name="name"/>
                        <field name="active" widget="boolean_toggle"/>
                        <field name="created_at" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biometric_person" model="ir.actions.act_window">
        <field name="name">Usuarios Biométricos</field>
        <field name="res_model">biometric.person</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_biometric_person_tree"/>
    </record>
</odoo>


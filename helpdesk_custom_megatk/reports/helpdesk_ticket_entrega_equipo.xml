<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_ticket_entrega_equipo" model="ir.actions.report">
        <field name="name">Entrega de Equipo (Ticket)</field>
        <field name="model">helpdesk.ticket</field>
        <field name="report_name">helpdesk_custom_megatk.helpdesk_ticket_entrega_equipo_template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="binding_model_id" ref="helpdesk.model_helpdesk_ticket"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="formatos_papel_mega.report_paperformat_8_0f21f71b"/>
        <field name="print_report_name">'Entrega de Equipo - %s' % (object.name)</field>
    </record>

    <template id="helpdesk_ticket_entrega_equipo_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="fields_megatk.external_layout_standard_soporte" t-lang="o.partner_id.lang">
                    <div class="page">
                        <div class="text-center" style="font-family:'Arial'; font-size:30pt;">
                            Entrega de Equipo
                        </div>
                        <br/>
                        <br/>
                        <br/>
                        <div style="float: right; margin-top: -30px;">
                            <h4>
                                Fecha Ingreso:
                                <span t-field="o.create_date" t-field-options='{"format": "dd-MM-yyyy HH:mm:ss"}'/>
                                &amp;nbsp;&amp;nbsp;
                                Fecha Entrega:
                                <span t-if="o.close_date" t-field="o.close_date" t-field-options='{"format": "dd-MM-yyyy"}'/>
                                <span t-if="not o.close_date" t-field="o.write_date" t-field-options='{"format": "dd-MM-yyyy"}'/>
                            </h4>
                        </div>

                        <table style="table-layout: fixed; width:100%">
                            <tr>
                                <td colspan="3" style="vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:22pt; text-align: center; background: rgb(13, 143, 210); ">
                                    Información del Cliente
                                </td>
                            </tr>
                            <tr>
                                <td style="word-wrap: break-word; vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;Cliente: <span t-esc="(o.partner_id and o.partner_id.name) or ''"/>
                                </td>
                                <td style="word-wrap: break-word; vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;Telefono: <span t-esc="o.x_studio_telfono or (o.partner_id and o.partner_id.phone) or ''"/>
                                </td>
                                <td style="word-wrap: break-word; vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;Email: <span t-esc="o.x_studio_correo_electrnico or (o.partner_id and o.partner_id.email) or ''"/>
                                </td>
                            </tr>
                        </table>

                        <table style="table-layout: fixed; width:100%">
                            <tr>
                                <td colspan="4" style="vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:22pt; text-align: center; background: rgb(13, 143, 210); ">
                                    Datos del Equipo
                                </td>
                            </tr>
                            <tr>
                                <td style="word-wrap: break-word; vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;# Serie: <span t-esc="o.x_studio_numero_de_serie or ''"/>
                                </td>
                                <td style="word-wrap: break-word; vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;Marca: <span t-esc="o.x_studio_marca or ''"/>
                                </td>
                                <td style="word-wrap: break-word; vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;Categoría: <span t-esc="o.x_studio_categoria or ''"/>
                                </td>
                                <td style="word-wrap: break-word; vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;Modelo: <span t-esc="o.x_studio_modelo or ''"/>
                                </td>
                            </tr>
                        </table>

                        <br/>

                        <table style="table-layout: fixed; width:100%">
                            <tr>
                                <td colspan="2" style="vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:22pt; text-align: center; background: rgb(13, 143, 210); ">
                                    Accesorios Incluidos
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-center" style="word-wrap: break-word; vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:14pt;">
                                    <span t-esc="o.x_studio_l or '(Ninguno)'"/>
                                </td>
                            </tr>
                        </table>

                        <table style="width:100%">
                            <tr>
                                <td colspan="2" style="vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:22pt; text-align: center; background: rgb(13, 143, 210); ">
                                    Estado del Equipo
                                </td>
                            </tr>
                            <tr>
                                <td style="word-wrap: break-word; width:10%; vertical-align:middle; border-bottom: 1px solid; border-left: 1px solid; border-right: 1px solid; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;Fallas:
                                </td>
                                <td style="width:90%; vertical-align:middle; border-bottom: 1px solid; border-left: 1px solid; border-right: 1px solid; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;<span t-esc="o.x_tecnico_diagnostico or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="word-wrap: break-word; width:10%; vertical-align:middle; border-bottom: 1px solid; border-left: 1px solid; border-right: 1px solid; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;Informe Técnico:
                                </td>
                                <td style="width:90%; vertical-align:middle; border-bottom: 1px solid; border-left: 1px solid; border-right: 1px solid; font-family:'Arial'; font-size:14pt;">
                                    &amp;nbsp;<span t-esc="o.x_tecnico_solucion or ''"/>
                                </td>
                            </tr>
                        </table>

                        <br/>
                        <span style="font-family:'Arial'; font-size:14pt;">&amp;nbsp;&amp;nbsp;Técnico Asignado:&amp;nbsp;<t t-esc="(o.user_id and o.user_id.name) or (o.create_uid and o.create_uid.name) or ''"/></span>
                        <br/>
                        <br/>
                        <br/>
                        <br/>
                        <br/>
                        <br/>

                        <table style="table-layout: fixed; width:100%">
                            <tr>
                                <td class="text-center" style="width:50%; vertical-align:middle;">
                                    <div style="width:90%; vertical-align:middle; border-top: 2px solid; font-family:'Arial'; font-size:14pt;">Firma del Cliente</div>
                                </td>
                                <td class="text-center" style="width:50%; vertical-align:middle;">
                                    <div style="width:90%; vertical-align:middle; border-top: 2px solid; font-family:'Arial'; font-size:14pt;">Firma del Técnico</div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

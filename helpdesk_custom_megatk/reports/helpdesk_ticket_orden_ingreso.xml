<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_ticket_orden_ingreso" model="ir.actions.report">
        <field name="name">Orden de Ingreso (Ticket)</field>
        <field name="model">helpdesk.ticket</field>
        <field name="report_name">helpdesk_custom_megatk.helpdesk_ticket_orden_ingreso_template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="binding_model_id" ref="helpdesk.model_helpdesk_ticket"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="formatos_papel_mega.report_paperformat_8_0f21f71b"/>
        <field name="print_report_name">'Orden de ingreso - %s' % (object.name)</field>
    </record>

    <template id="helpdesk_ticket_orden_ingreso_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 t-esc="o.name"/>
                        <table class="table table-bordered">
                            <tr>
                                <th>Cliente</th>
                                <td t-esc="o.partner_id.name" t-if="o.partner_id"/>
                            </tr>
                            <tr>
                                <th>Email</th>
                                <td t-esc="o.partner_id.email" t-if="o.partner_id"/>
                            </tr>
                            <tr>
                                <th>Teléfono</th>
                                <td t-esc="o.partner_id.phone" t-if="o.partner_id"/>
                            </tr>
                            <tr>
                                <th>Descripción</th>
                                <td t-esc="o.description"/>
                            </tr>
                            <tr>
                                <th>Equipo</th>
                                <td t-esc="o.team_id.name" t-if="o.team_id"/>
                            </tr>
                            <tr>
                                <th>Estado</th>
                                <td t-esc="o.stage_id.name" t-if="o.stage_id"/>
                            </tr>
                            <tr>
                                <th>Fecha Creación</th>
                                <td t-field="o.create_date" t-field-options='{"format": "dd-MM-yyyy"}'/>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

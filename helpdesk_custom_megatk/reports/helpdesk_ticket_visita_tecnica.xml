<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_ticket_visita_tecnica" model="ir.actions.report">
        <field name="name">Visita Técnica (Ticket)</field>
        <field name="model">helpdesk.ticket</field>
        <field name="report_name">helpdesk_custom_megatk.helpdesk_ticket_visita_tecnica_template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="binding_model_id" ref="helpdesk.model_helpdesk_ticket"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="formatos_papel_mega.report_paperformat_8_0f21f71b"/>
        <field name="print_report_name">'Visita Técnica - %s' % (object.name)</field>
    </record>

    <template id="external_layout_service_ticket">
        <div class="header">
            <div class="row" style="width: 100%; margin: 0; padding: 0 12px;">
                <div class="col-6" style="display: inline-block; width: 49%; vertical-align: middle;">
                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 56px;" alt="Logo"/>
                </div>
                <div class="col-6" style="display: inline-block; width: 49%; text-align: right; vertical-align: middle;">
                    <div style="font-family: Arial, sans-serif; font-size: 12pt; font-weight: 700; color: #0d8fd2;">
                        Soluciones tecnologicas para su empresa
                    </div>
                </div>
            </div>
            <div style="border-top: 1px solid #0d8fd2; margin-top: 8px;"/>
        </div>

        <div class="article o_report_layout_standard" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id">
            <t t-raw="0"/>
        </div>

        <div class="footer" style="font-size: 9pt;">
            <div style="border-top: 1px solid #0d8fd2; padding-top: 4px;">
                <div style="text-align: center;">
                    <span t-if="user.company_id.street" t-field="user.company_id.street"/>
                    <span t-if="user.company_id.street2">, <span t-field="user.company_id.street2"/></span>
                </div>
                <div style="text-align: center;">
                    <t t-if="user.company_id.phone">Tel: <span t-field="user.company_id.phone"/> </t>
                    <t t-if="user.company_id.email">| Correo: <span t-field="user.company_id.email"/> </t>
                    <t t-if="user.company_id.vat">| <t t-esc="user.company_id.country_id.vat_label or 'RTN'"/>: <span t-field="user.company_id.vat"/></t>
                </div>
                <div style="text-align: right;" class="text-muted">
                    Pag. <span class="page"/> / <span class="topage"/>
                </div>
            </div>
        </div>
    </template>

    <template id="helpdesk_ticket_visita_tecnica_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="helpdesk_custom_megatk.external_layout_service_ticket" t-lang="o.partner_id.lang">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 11pt;">
                        <h2 style="text-align: center; margin: 6px 0 10px 0; font-weight: 700;">
                            CONTROL DE VISITA
                        </h2>

                        <table style="width: 100%; table-layout: fixed; margin-bottom: 8px;">
                            <tr>
                                <td style="width: 50%;">
                                    <b>No.:</b> <span t-field="o.id"/>
                                </td>
                                <td style="width: 50%; text-align: right;">
                                    <b>Fecha:</b> <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y')"/>
                                </td>
                            </tr>
                        </table>

                        <table style="width: 100%; table-layout: fixed; border-collapse: collapse; margin-bottom: 8px;">
                            <tr>
                                <td colspan="3" style="border: 1px solid #000; padding: 6px;">
                                    <b>Empresa:</b> <span t-esc="(o.partner_id and o.partner_id.name) or ''"/>
                                </td>
                                <td style="border: 1px solid #000; padding: 6px;">
                                    <b>Telefono:</b> <span t-esc="o.x_studio_telfono or (o.partner_id and o.partner_id.phone) or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="4" style="border: 1px solid #000; padding: 6px;">
                                    <b>Persona que reporto:</b> <span t-esc="o.x_studio_la_persona_que_reporto or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="4" style="border: 1px solid #000; padding: 6px;">
                                    <b>Direccion:</b> <span t-esc="o.x_studio_direccin_de_visita or (o.partner_id and o.partner_id.street) or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="4" style="border: 1px solid #000; padding: 6px; min-height: 38px;">
                                    <b>Proposito de la visita:</b> <span t-esc="o.x_studio_propsito_de_la_visita or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="4" style="border: 1px solid #000; padding: 6px;">
                                    <b>Correo electronico:</b> <span t-esc="o.x_studio_correo_electrnico or (o.partner_id and o.partner_id.email) or ''"/>
                                </td>
                            </tr>
                        </table>

                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 8px;">
                            <tr>
                                <td style="border: 1px solid #000; padding: 4px 6px;"><b>Cortesia</b></td>
                                <td style="border: 1px solid #000; width: 26px; text-align: center;"><span t-if="(o.x_studio_tipo_de_visita or '').lower() in ['cortesia', 'cortesía']">X</span></td>
                                <td style="border: 1px solid #000; padding: 4px 6px;"><b>Contado</b></td>
                                <td style="border: 1px solid #000; width: 26px; text-align: center;"><span t-if="(o.x_studio_tipo_de_visita or '').lower() == 'contado'">X</span></td>
                                <td style="border: 1px solid #000; padding: 4px 6px;"><b>Garantia</b></td>
                                <td style="border: 1px solid #000; width: 26px; text-align: center;"><span t-if="(o.x_studio_tipo_de_visita or '').lower() in ['garantia', 'garantía']">X</span></td>
                                <td style="border: 1px solid #000; padding: 4px 6px;"><b>Capacitacion</b></td>
                                <td style="border: 1px solid #000; width: 26px; text-align: center;"><span t-if="(o.x_studio_tipo_de_visita or '').lower() in ['capacitacion', 'capacitación']">X</span></td>
                                <td style="border: 1px solid #000; padding: 4px 6px;"><b>Instalacion</b></td>
                                <td style="border: 1px solid #000; width: 26px; text-align: center;"><span t-if="(o.x_studio_tipo_de_visita or '').lower() in ['instalacion', 'instalación']">X</span></td>
                            </tr>
                        </table>

                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 8px;">
                            <tr>
                                <td style="border: 1px solid #000; padding: 6px; min-height: 46px;">
                                    <b>Visita realizada por:</b> <span t-esc="(o.user_id and o.user_id.name) or (o.create_uid and o.create_uid.name) or ''"/>
                                </td>
                            </tr>
                        </table>

                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 8px;">
                            <tr>
                                <td style="border: 1px solid #000; padding: 6px; min-height: 88px; vertical-align: top;">
                                    <b>Observaciones:</b> <span t-esc="o.x_tecnico_diagnostico or o.description or ''"/>
                                </td>
                            </tr>
                        </table>

                        <div style="page-break-inside: avoid; margin-top: 14px;">
                            <table style="width: 100%; table-layout: fixed;">
                                <tr>
                                    <td style="width: 48%; text-align: center; vertical-align: top; padding-right: 8px;">
                                        <div style="border-top: 1px solid #000; padding-top: 4px;">Trabajador</div>
                                    </td>
                                    <td style="width: 4%;"/>
                                    <td style="width: 48%; text-align: center; vertical-align: top; padding-left: 8px;">
                                        <div style="border-top: 1px solid #000; padding-top: 4px;">Cliente</div>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="tipo_estado_action" model="ir.actions.act_window">
        <field name="name">Propiedades</field>
        <field name="res_model">type.property</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_type_property" model="ir.ui.view">
        <field name="name">Tipo de propiedad</field>
        <field name="model">type.property</field>
        <field name="arch" type="xml">
            <tree string="Casa">
            <field name="name"/>
            </tree>
        </field>
    </record>
    <record id="etiqueta_action" model="ir.actions.act_window">
        <field name="name">Etiquetas</field>
        <field name="res_model">tag.property</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_tag_property" model="ir.ui.view">
        <field name="name">Etiquetas de propiedad</field>
        <field name="model">tag.property</field>
        <field name="arch" type="xml">
            <tree string="Etiqueta">
            <field name="name"/>
            </tree>
        </field>
        </record>
            <menuitem
                id="menu_configuraciones"
                name="Configuraciones"
                parent="estado_propiedad"
                sequence="30"/>
            <menuitem
                id="submenu_1_configuraciones"
                name="Tipo de propiedades"
                action="tipo_estado_action"
                parent="menu_configuraciones"
                sequence="10"/>
            <menuitem
                id="submenu_2_etiquetas"
                name="Etiquetas de propiedades"
                action="etiqueta_action"
                parent="menu_configuraciones"
                sequence="20"/>
           
</odoo>

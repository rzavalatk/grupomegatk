<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estado_propiedad_action" model="ir.actions.act_window">
        <field name="name">Propiedades</field>
        <field name="res_model">test.model</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_test_model_arbol" model="ir.ui.view">
        <field name="name">Propiedades</field>
        <field name="model">test.model</field>
        <field name="arch" type="xml">
            <tree string="Channel">
            <field name="name"/>
            <field name="postcode"/>
            <field name="bedrooms"/>
            <field name="living_area"/>
            <field name="expected_price"/>
            <field name="selling_price"/>
            <field name="date_availability"/>
            </tree>
        </field>
    </record>
    <record id="action_test_model_form" model="ir.ui.view">
        <field name="name">Mi nueva casa</field>
        <field name="model">test.model</field>
        <field name="arch" type="xml">
            <form string="Mi nueva casa">
                   <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="postcode"/>
                            </group>
                            <group>
                                <field name="expected_price"/>
                            </group>
                            <group>
                                <field name="date_availability"/>
                            </group>
                            <group>
                                <field name="selling_price"/>
                            </group>
                            <notebook>
                                <page string="Description">
                                    <group>
                                    <field name="description"/>
                                    </group>
                                    <group>
                                    <field name="bedrooms"/>
                                    </group>                                    
                                    <group>
                                    <field name="living_area"/>
                                    </group>                                    
                                    <group>
                                    <field name="facades"/>
                                    </group>                                    
                                    <group>
                                    <field name="garage"/>
                                    </group>                                    
                                    <group>
                                    <field name="garden"/>
                                    </group>                                    
                                    <group>
                                    <field name="garden_area"/>
                                    </group>                                    
                                    <group>
                                    <field name="garden_orientation"/>
                                    </group>
                                     <group>
                                    <field name="active"/>
                                    </group>
                                    <group>
                                    <field name="state"/>
                                    </group>
                                </page>
                            </notebook>
                        </group>
                    </sheet> 
            </form>
        </field>
    </record>
            <record id="view_delivery_carrier_search" model="ir.ui.view">
            <field name="name">Buscar</field>
            <field name="model">test.model</field>
            <field name="arch" type="xml">
                <search string="Delivery Carrier">
                        <field name="name"/>
                         <field name="postcode"/>
                         <field name="expected_price"/>
                         <field name="bedrooms"/>
                         <field name="living_area"/>
                         <field name="facades"/>
                         <field name="active"/>
                         <filter name="Propiedades disponibles" domain="[('state','=','New')]"/>
                </search>
            </field>
        </record>
            <menuitem
                id="estado_propiedad"
                name="Crear Propiedades"
                />
            <menuitem
                id="anuncio_propiedades"
                name="Anuncios"
                parent="estado_propiedad"
                sequence="10"/>
            <menuitem
                id="submenu_1_propiedades"
                name="Propiedades"
                action="estado_propiedad_action"
                parent="anuncio_propiedades"
                sequence="10"/>

</odoo>
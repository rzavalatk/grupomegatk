<odoo>
    <record id="view_recorrer_tickets_form" model="ir.ui.view">
        <field name="name">recorrer.tickets.form</field>
        <field name="model">recorrer.tickets</field>
        <field name="arch" type="xml">
            <form string="Recorrer Tickets">
                <header>
                         <button name="recorrer_tickets" type="object" string="Recorrer Tickets" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_recorrer_tickets" model="ir.actions.act_window">
        <field name="name">Recorrer Tickets</field>
        <field name="res_model">recorrer.tickets</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_recorrer_tickets_form"/>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_recorrer_tickets" name="Recorrer Tickets"
              action="action_recorrer_tickets" parent="base.menu_custom"/>
</odoo>

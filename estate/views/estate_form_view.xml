<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_property_view_form" model="ir.ui.view">
        <field name="name">estate.property.view.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <header>
                        <h1 style="decoration: none;">
                            <field name="name" readonly="True"/>
                        </h1>
                    </header>
                    <group style="display: grid; grid-template-columns: repeat(2, 30%); ">  
                        <div style="display: grid; grid-template-columns: repeat(2, 40%)">
                            <label for="postcode"/>
                            <field name="postcode" id="postcode"/>
                        </div>
                        <div style="display: grid; grid-template-columns: repeat(2, 50%);">
                            <label for="price_exp"/>
                            <field name="price_exp" id="price_exp"/>
                        </div>
                        <div style="display: grid; grid-template-columns: repeat(2, 50%);">
                            <label for="fecha_exist" style="display;=: inline-block"/>
                            <field name="fecha_exist" id="fecha_exist"/>
                        </div>
                        <div style="display: grid; grid-template-columns: repeat(2, 50%);">
                            <label for="price_sell"/>
                            <field name="price_sell" id="price_sell"/>
                        </div>
                    </group>
                    <notebook>
                        <page string="description">
                            <label for="description"/>
                            <div>
                                <field id="description" name="description"/>
                            </div>
                            <label for="bathrooms"/>
                            <field id="bathrooms" name="bathrooms"/>
                            <label for="state"/>
                            <field id="state" name="state"/>
                        </page>                                 
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>

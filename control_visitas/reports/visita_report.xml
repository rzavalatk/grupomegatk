<odoo>
    <template id="report_visita">
          <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2>Reporte de Visita</h2>
                    <p><strong>Nombre:</strong> <t t-esc="doc.name"/></p>
                    <p><strong>Fecha:</strong> <t t-esc="doc.date"/></p>
                    <p><strong>Descripción:</strong> <t t-esc="doc.description"/></p>
                </div>
            </t>
        </t>
    </template>

    <report id="action_report_visita"
            string="Reporte de Visitas"
            model="control.visitas"
            report_type="qweb-pdf"
            name="control_visitas.report_visita"
            file="control_visitas.report_visita"
            attachment_use="False"/>
</odoo>
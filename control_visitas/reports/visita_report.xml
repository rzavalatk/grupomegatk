<odoo>
    <template id="report_visita">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <div class="page">
                    <h2>Reporte de Visitas</h2>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Fecha</th>
                                <th>Región</th>
                                <th>Usuario</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs" t-as="visita">
                                <td><span t-field="visita.name"/></td>
                                <td><span t-field="visita.fecha"/></td>
                                <td><span t-field="visita.region"/></td>
                                <td><span t-field="visita.user_id"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <report id="action_report_visita"
            string="Reporte de Visitas"
            model="control.visitas"
            report_type="qweb-pdf"
            report_name="control_visitas.report_visita"
            paperformat="a4"
            attachment_use="False"/>
</odoo>
<odoo>
    <!-- Definición del template para el informe -->
    <template id="report_visitas">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <div class="page">
                    <h2>Reporte de Visitas</h2>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Fecha</th>
                                <th>Región</th>
                                <th>Usuario</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs" t-as="visita">
                                <td><span t-field="visita.name"/></td>
                                <td><span t-field="visita.fecha"/></td>
                                <td><span t-field="visita.region"/></td>
                                <td><span t-field="visita.user_id"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

     <record id="action_report_visitas" model="ir.actions.report">
        <field name="name">Registros PDF</field>
        <field name="model">control.visitas</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">control_visitas.report_visitas</field>
        <field name="report_file">control_visitas.report_visitas</field>
        <field name="binding_type">report</field>
    </record> 
</odoo>
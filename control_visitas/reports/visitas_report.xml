<odoo>
    <!-- Definición del template para el informe -->
    <template id="report_visitas_template">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <div class="page">
                    <h2>Reporte de Visitas</h2>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Región</th>
                                <th>Usuario</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="docs" t-as="visita">
                                <td><span t-field="visita.visita_diaria.name"/></td>
                                <td><span t-field="visita.visita_diaria.fecha"/></td>
                                <td><span t-field="visita.visita_diaria.hora"/></td>
                                <td><span t-field="visita.visita_diaria.region"/></td>
                                <td><span t-field="visita.visita_diaria.user_id"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <record id="control_visitas_report_pdf_action" model="ir.actions.report">
        <field name="name">Registros PDF</field>
        <field name="model">registro.visitas</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">control_visitas.report_visitas_template</field>
        <field name="report_file">control_visitas.report_visitas_template</field>
        <field name="binding_type">report</field>
    </record>
</odoo>
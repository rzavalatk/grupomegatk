<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="control_visita_action" model="ir.actions.client">
            <field name="name">Control de Visitas</field>
            <field name="tag">control_visitas_tag</field>
        </record>
        <menuitem id="control_visitas_menu_root"
                  name="Control de Visitas"
                  action="control_visita_action"
                  web_icon="control_visitas,static/description/control.png"
                  sequence="1"/>

        <record id="control_visitas_report_action" model="ir.actions.act_window">
            <field name="name">Reporte de Visitas</field>
            <field name="res_model">control.visitas</field>
            <field name="view_mode">graph,search</field>
        </record>

        <menuitem id="control_visitas_report"
                  name="Reportes"
                  parent="control_visitas_menu_root"
                  sequence="2"
                  action="control_visitas_report_action"/>

        <record id="control_visitas_record_action" model="ir.actions.act_window">
            <field name="name">Registros de Visitas</field>
            <field name="res_model">control.visitas</field>
            <field name="view_mode">tree</field>
        </record>

        <menuitem id="control_visitas_record"
                  name="Registros"
                  parent="control_visitas_menu_root"
                  sequence="3"
                  action="control_visitas_record_action"/>

        <menuitem
            id="menu_visitas_report_pdf"
            name="Reporte de visitas (PDF)"
            action="action_report_visitas"
            parent="control_visitas_menu_root"
            sequence="10"/>


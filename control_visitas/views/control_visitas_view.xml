<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="control_visitas_view_tree" model="ir.ui.view">
    <field name="name">control.visitas.view.tree</field>
    <field name="model">control.visitas</field>
    <field name="arch" type="xml">
        <header>
            <button string="Enviar Reporte por Correo"
                        type="object"
                        class="btn-primary oe_highlight"
                        name="enviar_correo_con_reporte"/>
        </header>
        <tree>
            <sheet>
                <field name="name"/>
                <field name="fecha"/>
                <field name="region"/>
            </sheet>
        </tree>
    </field>
</record>
</odoo>
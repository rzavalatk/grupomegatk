<odoo>
    <record id="view_visitas_buttons" model="ir.ui.view">
        <field name="name">control.visitas.buttons</field>
        <field name="model">control.visitas</field>
        <field name="arch" type="xml">
            <form>
                <div style="display: grid; grid-template-columns: repeat(2, 50%);">
                    <button style="padding: 15px 0" string="Visita Administración" type="object" name="visita_administracion"/>
                    <button style="padding: 15px 0" string="Visita Tienda Meditek" type="object" name="visita_tienda_meditek"/>
                    <button style="padding: 15px 0" string="Visita Lenka" type="object" name="visita_lenka"/>
                    <button style="padding: 15px 0" string="Visita Clínica" type="object" name="visita_clinica"/>
                    <button style="padding: 15px 0" string="Visita Tienda MegaTK" type="object" name="visita_tienda_megatk"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_visitas_tree" model="ir.ui.view">
        <field name="name">control.visitas.tree</field>
        <field name="model">control.visitas</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="fecha"/>
                <field name="region"/>
                <field name="zona"/>
            </tree>
        </field>
    </record>


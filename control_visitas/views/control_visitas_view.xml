<odoo>

    <menuitem id="menu_visitas_root" name="Control Visitas" sequence="10" web_icon="control_visitas/description/REPORTES.png"/>

    <record id="action_visitas" model="ir.actions.act_window">
        <field name="name">Registro</field>
        <field name="res_model">control.visitas</field>
        <field name="view_mode">tree,form</field>
    </record>
    
    <menuitem id="menu_visitas" name="Reportes" parent="menu_visitas_root" sequence="20" action="action_visitas"/>

    <record id="view_visitas_buttons" model="ir.ui.view">
        <field name="name">control.visitas.buttons</field>
        <field name="model">control.visitas</field>
        <field name="arch" type="xml">
            <form>
                <div style="display: grid; grid-template-columns: repeat(2, 30%);">
                    <div>
                        <button class="oe_highlight" string="Visita Administración" type="object" name="visita_administracion"/>
                    </div>
                    <div>
                        <button class="oe_highlight" string="Visita Tienda Meditek" type="object" name="visita_tienda_meditek"/>
                    </div>
                    <div>
                        <button class="oe_highlight" string="Visita Lenka" type="object" name="visita_lenka"/>
                    </div>
                    <div>
                        <button class="oe_highlight" string="Visita Clínica" type="object" name="visita_clinica"/>
                    </div>
                    <div>
                        <button class="oe_highlight" string="Visita Tienda MegaTK" type="object" name="visita_tienda_megatk"/>
                    </div>
                </div>
            </form>
        </field>
    </record>

    <record id="view_visitas_tree" model="ir.ui.view">
        <field name="name">control.visitas.tree</field>
        <field name="model">control.visitas</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="fecha"/>
                <field name="region"/>
                <field name="zona"/>
            </tree>
        </field>
    </record>

    <!-- <record id="view_visitas_form" model="ir.ui.view">
        <field name="name">control.visitas.form</field>
        <field name="model">control.visitas</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="fecha"/>
                        <field name="region"/>
                        <field name="zona"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record> -->

    
</odoo>
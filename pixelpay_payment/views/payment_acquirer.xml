<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="provider_form_pixel" model="ir.ui.view">
            <field name="name">Pixelpay Provider Form</field>
            <field name="model">payment.provider</field>
            <field name="inherit_id" ref="payment.payment_provider_form"/>
            <field name="arch" type="xml">

                <field name="name" placeholder="Nombre" modifiers="{&quot;required&quot;: true}"/>
                <xpath expr="//sheet" position="before">
                    <header>
                        <button string="get provinces"
                             type="object"
                             name="get_country_provinces"
                             class="oe_highlight"
                             confirm="Are you sure you have selected a country in the module settings?"
                             attrs="{'invisible': [('code', '!=', 'pixel')]}"
                        />
                    </header>
                </xpath>

                <xpath expr='//field[@name="name"]' position='replace'>
                    <field name="name" placeholder="Nombre" modifiers="{'required': true}" attrs="{'readonly': [('code', '=', 'pixel')]}"/>
                </xpath>

                <xpath expr='//group[@name="provider"]' position='inside'>
                    <group attrs="{'invisible': [('code', '!=', 'pixel')]}">
                        <field name="pixel_endpoint" attrs="{'required':[('code', '=', 'pixel'), ('state', '=', 'enabled')]}"/>
                        <field name="pixel_key" attrs="{'required':[('code', '=', 'pixel'), ('state', '=', 'enabled')]}"/>
                        <field name="pixel_secret_key" attrs="{'required':[('code', '=', 'pixel'), ('state', '=', 'enabled')]}" password="True"/>
                    </group>
                </xpath>
                
                <xpath expr='//field[@name="display_as"]' position='replace'>
                    <field name="display_as" placeholder="If not defined, the provider name will be used."
                    attrs="{'readonly': [('code', '=', 'pixel')]}"/>
                </xpath>
                
                <field name="display_as" position="before">
                    <field name="pixel_payment_method_type"
                           attrs="{'invisible': [('code', '!=', 'pixel')], 'required':[('code', '=', 'pixel'), ('state', '!=', 'disabled')]}"/>
                </field>

                <xpath expr='//field[@name="allow_tokenization"]' position='attributes'>
                    <attribute name="nolabel">1</attribute>
                </xpath>
                
                <xpath expr='//field[@name="allow_tokenization"]' position='before'>
                    <div>
                    <label for="allow_tokenization" string="Activate tokenization" attrs="{'invisible':[('code', '!=', 'pixel')]}"/>
                    <label for="allow_tokenization" string="Allow Saving Payment Methods" attrs="{'invisible':[('code', '=', 'pixel')]}"/>
                    </div>
                </xpath>

                <xpath expr="//page[@name='messages']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!--        Default GroupBy-->
        <record id="cuota_default_group" model="ir.ui.view">
            <field name="name">cuota.default.group</field>
            <field name="model">cuota</field>
            <field name="arch" type="xml">
                <search string="Prestamo">
                    <filter name="prestamo_id" string="Prestamo ID" context="{'group_by': 'prestamo_id'}"/>
                </search>
            </field>
        </record>

        <!--        Cuota Action-->
        <record id="cuota_action" model="ir.actions.act_window">
            <field name="name">Cuota acción</field>
            <field name="res_model">cuota</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_loan': 1}</field>
            <field name="search_view_id" ref="cuota_default_group"/>
        </record>

        <!--        Cuota Tree View-->
        <record id="cuota_view_tree" model="ir.ui.view">
            <field name="name">cuota.view.tree</field>
            <field name="model">cuota</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Prestamos" create="false">
                    <field name="name"/>
                    <field name="res_partner_id"/>
                    <field name="prestamo_id"/>
                    <field name="date_due"/>
                    <field name="amount"/>
                    <field name="company_id"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!--        Cuota Form View -->
        <record id="cuota_view_form" model="ir.ui.view">
            <field name="name">cuota.view.form</field>
            <field name="model">cuota</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Cuota form" create="false">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="unpaid,pagado"/>
                        <button attrs="{'invisible': ['|', ('invoice', '=', True), ('state', '!=', 'unpaid')]}"
                                name="action_pay_emi"
                                class="oe_highlight"
                                string="Pagar"
                                type="object"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" style="width: 50%%;"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="res_partner_id"/>
                                <field name="prestamo_id"/>
                            </group>
                            <group>
                                <field name="date_due"/>
                                <field name="amount_capital_quota"/>
                                <field name="interest_generated"/>
                                <field name="amount"/>
                                <field name="invoice" invisible="1"/>
                            </group>
                            <group>
                                <field name="company_id"/>
                            </group>
                        </group>
                        
                    </sheet>
                </form>
            </field>
        </record>
</odoo>
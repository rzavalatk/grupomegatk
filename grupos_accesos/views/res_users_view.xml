<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="view_users_form_invoice_warehouse_restriction" model="ir.ui.view">
            <field name="name">res.users.form.invoice.warehouse.restriction</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='access_rights']" position="after">
                    <page name="invoice_warehouse_restriction" string="Facturacion por Almacen">
                        <group>
                            <field name="allowed_invoice_warehouse_ids" widget="many2many_tags" options="{'no_create_edit': True, 'no_create': True}"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

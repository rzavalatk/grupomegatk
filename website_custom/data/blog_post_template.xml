<!-- Tu módulo: views/blog_post_template.xml -->
<odoo>
    <data>
        <!-- Extiende la plantilla de notificación de blog post -->
        <template id="blog_post_template_new_post_inherit" inherit_id="blog.blog_post_template_new_post">
            <xpath expr="//a[@t-attf-href]" position="attributes">
                <!-- Usa el dominio del website asociado con la publicación para la URL -->
                <attribute name="t-attf-href">#{post.website_id.domain}/blog/#{slug(object)}/#{slug(post)}</attribute>
            </xpath>
        </template>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_update_gps_positions" model="ir.cron">
        <field name="name">Actualizar GPS cada minuto</field>
        <field name="model_id" ref="model_gps_device_trip"/>
        <field name="state">code</field>
        <field name="code">model.fetch_device_positions()</field>
        <field name="interval_number">3</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>

<odoo>
    <record id="view_gps_device_trip_tree" model="ir.ui.view">
        <field name="name">gps.device.trip.tree</field>
        <field name="model">gps.device.trip</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="device_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <template id="LeafletMap" name="Leaflet Map Template">
        <div class="leaflet-map-container" style="height: 400px; width: 100%;"></div>
    </template>

    <record id="view_gps_device_trip_form" model="ir.ui.view">
        <field name="name">gps.device.trip.form</field>
        <field name="model">gps.device.trip</field>
        <field name="arch" type="xml">
            <form> 
                <header>
                    <button name="fetch_device_positions" type="object" string="Actualizar Ubicaciones" class="btn-primary" attrs="{'invisible': [('state', 'in', ['new','finished'])]}"/>
                    <button name="action_start_trip" type="object" string="Iniciar Viaje" class="btn-primary" attrs="{'invisible': [('state', 'in', ['ongoing', 'finished'])]}" />
                    <button name="finish_trip" type="object" string="Finalizar Viaje" class="btn-danger" attrs="{'invisible': [('state', 'in', ['finished','new'])]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="new, ongoing, finished"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1 class="">
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="device_id"/>
                        <field name="start_time" readonly='1' />
                        <field name="end_time" readonly='1' />
                        <field name="tiempo_usado" readonly='1' />
                        <field name="tiempo_iniciado" invisible="1"/>
                        <div>
                            <button name="llegada" type="object" class="btn-primary">
                                <field name="hora_llegada" string="Inicio" widget="statinfo"/>
                            </button>
                        </div>
                        <div>
                            <button name="salida" type="object" class="btn-primary">
                                <field name="hora_salida" string="Final" widget="statinfo"/>
                            </button>
                        </div>
                    </group>
                    <notebook>
                        <page string="Ubicaciones">
                            <field name="location_ids">
                                <tree editable="false" create="false" delete="false">
                                    <field name="timestamp" readonly='1'/>
                                    <field name="latitude" readonly='1'/>
                                    <field name="longitude" readonly='1'/>
                                    <field name="map_btn" widget="html" readonly='1'/>
                                </tree>
                            </field>
                        </page>
                        <page string="Mapa del Viaje">
                            <div class="oe_title">
                                <h2>Ruta del Dispositivo</h2>
                                <map res_partner="name" default_order="admn_code" routing="true" hide_name="true">
                                    <field name="devide_id" string="ID"/>
                                    <field name="name" string="Nombre"/>
                                </map>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gps_device_trip" model="ir.actions.act_window">
        <field name="name">Viajes GPS</field>
        <field name="res_model">gps.device.trip</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

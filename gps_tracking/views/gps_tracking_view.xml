<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_gps_device_location_tree" model="ir.ui.view">
        <field name="name">gps.device.location.tree</field>
        <field name="model">gps.device.location</field>
        <field name="arch" type="xml">
            <tree>
                <header>
                    <button name="fetch_traccar_positions"
                            string="Actualizar ubicaciones"
                            type="object"
                            class="btn-primary"
                            icon="fa-refresh"/>
                </header>
                <field name="device_id"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="speed"/>
                <field name="timestamp"/>
                <field name="address"/>
            </tree>
        </field>
    </record>

    <record id="action_gps_device_location" model="ir.actions.act_window">
        <field name="name">Ubicaciones GPS</field>
        <field name="res_model">gps.device.location</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_gps_device_location_root"
              name="GPS"
              sequence="10"
              web_icon="localizacion,static/description/localizar.png"/>

    <menuitem id="menu_gps_device_location"
              name="Ubicaciones GPS"
              parent="menu_gps_device_location_root"
              action="action_gps_device_location"
              sequence="1"/>
</odoo>

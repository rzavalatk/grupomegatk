<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="TrackingCardMenu">
        <div class="row">
            <style>
                <!-- utilidades -->
                .flex-content-center {
                    display: flex;
                    justify-content: center;
                }

                .conteiner-btn {
                    display: flex;
                    justify-content: flex-end;
                }

                .flex-column {
                    display: flex;
                    flex-direction: column;
                }

                .flex-end {
                    justify-content: flex-end;
                }

                .text-bold {
                    font-weight: bold;
                }

                <!-- tarjeta -->
                .menu-card {
                    align-items: center;
                    background-color: #242733; 
                    height: 350px; 
                    width: 400px; 
                    border-radius: 0 0 10px 10px;
                    padding: 30px;
                }

                .banner {
                    background-image: linear-gradient(to right, #004080, #0080ff);
                    height: 60px;
                    width: 400px; 
                    border-radius: 10px 10px 0 0;
                }

                .card-title {
                    font-size: 40px;
                    text-align: center;
                }

                .card-text {
                    font-size: 18px;
                    text-align: center;
                }

                .card-input {
                    border: none;
                    border-bottom-style: outset;
                    width: 50%;
                    background-color: #242733;
                    margin-top: 10px;
                    font-size: 20px;
                    text-align: center;
                }

                .btn-start {
                    background-color: #33cc33;
                }
            </style>
            <div id="root">
                <div class="container flex-content-center pt-5">
                    <div>
                        <div class="banner"></div>
                        <div class="menu-card flex-column">
                            <t t-if="1 == 1">
                                <h2 class="card-title">¡Bienvenido!</h2>
                            </t>
                            <t t-else="">
                                <h2 class="card-title">En Curso</h2>
                            </t>
                            <t t-if="1 == 1">
                                <p class="card-text">Para iniciar un viaje ingrese el ID del dispositivo</p>
                                <input type="text" class="card-input" id="id_device"/>
                            </t>
                            <t t-else="">
                                <p class="card-text">¿Desea finalizar el viaje? Una vez finalizado no se puede reactivar</p>
                            </t>
                            <div class="flex-grow-1 conteiner-btn">
                                <button t-attf-class="o_hr_attendance_sign_in_out_icon btn btn-{{ 1 == 0 ? 'warning' : 'success' }} align-self-center px-5 py-3 mt-4 mb-2">
                                    <span class="text-bold align-middle fs-2 me-3 text-white" t-if="!(1 == 0)">Iniciar Viaje</span>
                                    <i t-attf-class="fa fa-4x fa-sign-{{ 1 == 1 ? 'out' : 'in' }} align-middle"/>
                                    <span class="text-bold align-middle fs-2 ms-3" t-if="1 == 0">Finalizar Viaje</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>

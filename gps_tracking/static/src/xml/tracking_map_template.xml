<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="TrackingMap">
        <div class="row">
            <style>
                .map-container {
                    display: flex;
                    justify-content: space-evenly;
                }
            </style>
            <div id="root">
                <div class="container pt-5 map-container">
                    <div>
                        <h1>Mapa Leaflet.js</h1>
                        <div id="map" style="height: 400px; width: 400px;"></div>
                    </div>
                    <div>
                        <h2 class="">Ingresar codigo de viaje</h2>
                        <input type="text" class="card-input" id="id_device" pattern='\d{6}' minlength="8" maxlength="8" required="true"/>
                        <div class="">
                            <button class="">a</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>

<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="TrackingMap">
        <div class="row">
            <style>
                .menu-container {
                    display: flex;
                    justify-content: space-evenly;
                }

                #map {
                    height: 500px;
                    width: 700px;
                    border-radius: 15px;
                }

                .banner {
                    background-image: linear-gradient(to right, #004080, #0080ff);
                    height: 60px;
                    width: 400px; 
                    border-radius: 10px 10px 0 0;
                }

                .card-title {
                     font-size: 30px;
                     font-weight: bold;
                }

                .card-input {
                    border: none;
                    border-bottom-style: outset;
                    width: 50%;
                    background-color: #242733;
                    margin-top: 10px;
                    font-size: 20px;
                    text-align: center;
                }

                .grid-panel {
                    display: grid;
                    grid-template-rows: 13% 43% 44%;
                    background-color: #242733;
                    border-radius: 10px;
                }

                .grid-section {
                    display: grid;
                    grid-template-rows: repeat(3, 1fr);
                    padding: 20px;
                    gap: 12px;
                }
            </style>
            <div id="root">
                <div class="container pt-5 menu-container">
                    <div>
                        <h1>Mapa Leaflet.js</h1>
                        <div id="map"></div>
                    </div>
                    <div class="grid-panel">
                        <div class="banner"></div>
                        <div class="grid-section">
                            <h2 class="">Ingresar codigo de viaje</h2>
                            <input type="text" class="card-input" id="id_device" pattern='\d{6}' minlength="8" maxlength="8" required="true"/>
                            <div class="">
                                <button class="">Mostrar ruta</button>
                            </div>
                        </div>
                        <div class="grid-section">
                            <div class="">
                                <label for="" class="">Empleado</label>
                                <p class="">aaa</p>
                            </div>
                            <div class="">
                                <label for="" class="">ID Dispositivo</label>
                                <p class="">aaa</p>
                            </div>
                            <div class="">
                                <label for="" class="">Empleado</label>
                                <p class="">aaa</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="inherit_view_vending_machine" model="ir.ui.view">
        <field name="name">hr.employee.base.inherit.vending</field>
        <field name="model">attr.employee</field>
        <field name="inherit_id" ref="hr_employee.view_employee_tree"/>
        <field name="arch" type="xml">
            <tree string = "Editar datos de empleados para VM" editable="top">
            <field name="name"/>
            <field name="credit"/>
            <field name="number_card"/>
            <field name="available_credit"/>
            </tree>
        </field>
    </record>
     <record id="new_credit_view" model="ir.actions.act_window">
            <field name="name">Credito vending machine</field>
            <field name="res_model">hr.employee.base</field>
            <field name="view_mode">tree</field>
        </record>
    <menuitem
        id="menu_hr_vm"
        name="Vending machine"
        sequence="45"
        parent="hr.menu_hr_root"/>

    <menuitem
        id="model_name_menu"
        name="vending compras"
        action = "open_view_employee_tree_new"
        sequence="2"
        parent = "menu_hr_vm"/>

</odoo>

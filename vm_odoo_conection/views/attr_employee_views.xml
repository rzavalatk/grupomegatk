<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Nueva vista de árbol para la Vending Machine -->
    <record id="view_vending_employee_tree" model="ir.ui.view">
        <field name="name">vending.employee.tree</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <tree string="Empleados crédito" editable="top">
                <field name="name" readonly="1"/>
                <field name="credito" readonly="1"/>
                <field name="credito_disponible"/>
                <field name="numero_tarjeta" class="text-right"/>  
            </tree>
        </field>
    </record>

    <!-- Acción para abrir la nueva vista de árbol -->
    <record id="action_open_vending_employee_tree" model="ir.actions.act_window">
        <field name="name">Empleado crédito</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_vending_employee_tree"/>
        <field name="context">{'search_default_filter_employees': 1}</field>
        <field name="domain">[]</field>
    </record>

    <!-- Agregar el botón en la toolbar base de Odoo -->
    <record id="base_toolbar_button" model="ir.ui.view">
        <field name="name">base.toolbar.button</field>
        <field name="model">ir.ui.view</field>
        <field name="inherit_id" ref="web.layout"/>
        <field name="arch" type="xml">
            <!-- Agregar el botón en la toolbar base -->
            <xpath expr="//div[@class='o_cp_buttons']" position="inside">
                <button string="Recargar Créditos" type="object" name="recargar_credito" class="btn-primary"/>
            </xpath>
        </field>
    </record>

    <!-- Menú principal -->
    <menuitem
        id="menu_hr_vm"
        name="Vending machine"
        sequence="45"
        parent="hr.menu_hr_root"/>

    <!-- Submenú que abre la nueva vista de árbol -->
    <menuitem
        id="model_name_menu"
        name="Empleados"
        action="action_open_vending_employee_tree"
        sequence="2"
        parent="menu_hr_vm"/>
</odoo>
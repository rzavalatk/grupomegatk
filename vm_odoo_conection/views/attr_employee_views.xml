<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Nueva vista de árbol para la Vending Machine -->
    <record id="view_vending_employee_tree" model="ir.ui.view">
        <field name="name">vending.employee.tree</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <tree string="Empleados crédito" editable="top">
                <field name="name" readonly="1"/>
                <field name="credito" readonly="1"/>
                <field name="credito_disponible"/>
                <field name="numero_tarjeta" class="text-right"/>  
            </tree>
        </field>
    </record>

    <!-- Acción para abrir la nueva vista de árbol con el botón en la barra superior -->
    <record id="action_open_vending_employee_tree" model="ir.actions.act_window">
        <field name="name">Empleado crédito</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_vending_employee_tree"/>
        <field name="context">{'search_default_filter_employees': 1}</field>
        <field name="domain">[]</field>
    </record>

    <!-- Botón en la barra de acciones de la vista -->
    <record id="hr_employee_action_server" model="ir.actions.server">
        <field name="name">Recargar Créditos</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">
        </field>
    </record>

    
    <record id="hr_employee_action_toolbar" model="ir.ui.view">
        <field name="name">hr.employee.tree.toolbar</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
             <xpath expr="//div[@class='o_control_panel']" position="inside">
                <button name="hr_employee_action_server" type="action" string="Recargar Créditos" class="btn-primary"/>
            </xpath>
        </field>
    </record>

    <!-- Menú principal -->
    <menuitem
        id="menu_hr_vm"
        name="Vending machine"
        sequence="45"
        parent="hr.menu_hr_root"/>

    <!-- Submenú que abre la nueva vista de árbol -->
    <menuitem
        id="model_name_menu"
        name="Empleados"
        action="action_open_vending_employee_tree"
        sequence="2"
        parent="menu_hr_vm"/>
</odoo>

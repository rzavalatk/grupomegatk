<odoo>
    <record id="new_view_tree" model="ir.ui.view">
        <field name="name">hr.employee.newview.tree</field>
        <field name="model">attr.employee</field>
        <field name="arch" type="xml">
            <tree string="Editar datos de empleados para VM" editable="top">

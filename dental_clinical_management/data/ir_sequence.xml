<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--  Secuencia para receta  -->
    <record id="seq_dental_prescription" model="ir.sequence">
        <field name="name">Recetas dentales</field>
        <field name="code">dental.prescriptions</field>
        <field name="prefix">RCT</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>
    <!--  Secuencia para cita  -->
    <record id="seq_dental_appointment" model="ir.sequence">
        <field name="name">Citas dentales</field>
        <field name="code">dental.appointment</field>
        <field name="prefix">CTA</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>

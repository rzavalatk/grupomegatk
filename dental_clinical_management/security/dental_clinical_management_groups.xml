<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Crear la categoria para los grupos de clinica dental -->
        <record id="module_category_dental_clinic" model="ir.module.category">
            <field name="name">Clinica dental</field>
            <field name="sequence">18</field>
        </record>
        <!-- se crea el grupo solo como documentos propios y estos grupos solo accederán a sus propios datos -->
        <record id="group_dental_doctor" model="res.groups">
            <field name="name">Usuario: Solo documentos propios</field>
            <field name="category_id" ref="module_category_dental_clinic"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">el usuario tendrá acceso a sus propios datos en
                la
                aplicación de clínica dental.
            </field>
        </record>
        <!-- se crea el grupo como Manager y estos grupos pueden ver todos los datos -->
        <record id="group_dental_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="comment">el usuario tendrá acceso a toda la configuración de la clínica dental.
            </field>
            <field name="category_id" ref="module_category_dental_clinic"/>
            <field name="implied_ids" eval="[(4, ref('group_dental_doctor'))]"/>
            <field name="users" eval="[(4, ref('base.user_root'))]"/>
        </record>
    </data>
</odoo>

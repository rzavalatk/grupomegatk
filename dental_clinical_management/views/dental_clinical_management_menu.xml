<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Acción de menú para Citas Dentales-->
    <record id="dental_appointment_menu_action" model="ir.actions.act_window">
        <field name="name">Citas de Doctores</field>
        <field name="res_model">dental.appointment</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_today': True}</field>
    </record>
    <!--Acción de menú para Doctores Dentales-->
    <record id="dental_doctor_menu_action" model="ir.actions.act_window">
        <field name="name">Doctores</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--Acción de menú para Pacientes Dentales-->
    <record id="dental_patients_menu_action" model="ir.actions.act_window">
        <field name="name">Pacientes</field>
        <field name="res_model">res.partner</field>
        <field name="domain">[('is_patient','=',True)]</field>
        <field name="context">{'default_company_type':'person'}</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--Acción de menú para Prescripción Dental-->
    <record id="dental_prescription_menu_action" model="ir.actions.act_window">
        <field name="name">Prescripción Dental</field>
        <field name="res_model">dental.prescription</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_today': True}</field>
    </record>
    <!--Acción de menú para Especialista Dental-->
    <record id="dental_specialist_menu_action" model="ir.actions.act_window">
        <field name="name">Especializado</field>
        <field name="res_model">dental.specialist</field>
        <field name="view_mode">tree</field>
    </record>
    <!--Acción de menú para Categoría de Tratamiento-->
    <record id="treatment_category_menu_action" model="ir.actions.act_window">
        <field name="name">Categoría de Tratamiento</field>
        <field name="res_model">treatment.category</field>
        <field name="view_mode">tree</field>
    </record>
    <!--Acción de menú para Tratamiento Dental-->
    <record id="dental_treatment_menu_action" model="ir.actions.act_window">
        <field name="name">Tratamiento Dental</field>
        <field name="res_model">dental.treatment</field>
        <field name="view_mode">tree</field>
    </record>
    <!--Acción de menú para Medicinas Dentales-->
    <record id="medicines_menu_action" model="ir.actions.act_window">
        <field name="name">Medicinas</field>
        <field name="res_model">product.template</field>
        <field name="domain">[('is_medicine','=',True)]</field>
        <field name="context">{'default_is_medicine':True,
            'default_detailed_type': 'product'}
        </field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--Acción de menú para Frecuencia de Medicina-->
    <record id="medicine_frequency_menu_action" model="ir.actions.act_window">
        <field name="name">Frecuencia de Medicina</field>
        <field name="res_model">medicine.frequency</field>
        <field name="view_mode">tree</field>
    </record>
    <!--Acción de menú para Compañía de Seguros-->
    <record id="insurance_company_menu_action" model="ir.actions.act_window">
        <field name="name">Compañía de Seguros</field>
        <field name="res_model">insurance.company</field>
        <field name="view_mode">tree</field>
    </record>
    <!--Acción de menú para Turnos Dentales-->
    <record id="dental_time_shift_menu_action" model="ir.actions.act_window">
        <field name="name">Turno Dental</field>
        <field name="res_model">dental.time.shift</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--Acción de menú para Preguntas Médicas-->
    <record id="medical_questions_menu_action" model="ir.actions.act_window">
        <field name="name">Preguntas Médicas</field>
        <field name="res_model">medical.questions</field>
        <field name="view_mode">tree</field>
    </record>
    <!--Acción de menú para Reportes de Rayos X-->
    <record id="report_menu_action" model="ir.actions.act_window">
        <field name="name">reporte</field>
        <field name="res_model">xray.report</field>
        <field name="view_mode">form</field>
    </record>
    <!-- Menús Agregados-->
    <menuitem id="dentist_menu_root"
              web_icon="dental_clinical_management,static/description/icon.png"
              name="Clínica Dental"/>
    <menuitem id="dentist_menu_root" name="Clínica Dental"
              action="dental_appointment_menu_action"/>
    <menuitem id="appointments_main_menu" name="Citas"
              parent="dentist_menu_root" sequence="1"
              action="dental_appointment_menu_action"/>
    <menuitem id="prescriptions_main_menu" name="Prescripciones"
              parent="dentist_menu_root" sequence="2"
              action="dental_prescription_menu_action"/>
    <menuitem id="patients_main_menu" name="Pacientes" parent="dentist_menu_root"
              sequence="3" action="dental_patients_menu_action"/>
    <menuitem id="dentist_main_menu" name="Dentista" parent="dentist_menu_root"
              sequence="4" action="dental_doctor_menu_action"/>
    <menuitem id="config_main_menu" name="Configuración"
              parent="dentist_menu_root" sequence="5"/>
    <menuitem id="physicians_main_menu" name="Médicos"
              parent="config_main_menu" sequence="1"/>
    <menuitem id="department_main_menu" name="Departamento"
              parent="physicians_main_menu" sequence="1"
              action="hr.hr_department_tree_action"/>
    <menuitem id="specialist_main_menu" name="Especializado"
              parent="physicians_main_menu" sequence="2"
              action="dental_specialist_menu_action"/>
    <menuitem id="dental_time_shift" name="Turno"
              parent="physicians_main_menu" sequence="3"
              action="dental_time_shift_menu_action"/>
    <menuitem id="medical_procedures_main_menu" name="Procedimientos Médicos"
              parent="config_main_menu" sequence="2"/>
    <menuitem id="treatment_categories_main_menu" name="Categorías de Tratamiento"
              parent="medical_procedures_main_menu" sequence="1"
              action="treatment_category_menu_action"/>
    <menuitem id="treatment_main_menu" name="Tratamiento"
              parent="medical_procedures_main_menu" sequence="2"
              action="dental_treatment_menu_action"/>
    <menuitem id="medicines_main_menu" name="Medicinas"
              parent="medical_procedures_main_menu" sequence="3"
              action="medicines_menu_action"/>
    <menuitem id="medicine_frequency_main_menu" name="Frecuencia de Medicamento"
              parent="medical_procedures_main_menu" sequence="4"
              action="medicine_frequency_menu_action"/>
    <menuitem id="medical_questions_main_menu" name="Preguntas Médicas"
              parent="medical_procedures_main_menu" sequence="5"
              action="medical_questions_menu_action"/>
    <menuitem id="insurance_main_menu" name="Seguros"
              parent="config_main_menu" sequence="3"/>
    <menuitem id="insuarnce_company_main_menu" name="Compañía de Seguros"
              parent="insurance_main_menu" sequence="1"
              action="insurance_company_menu_action"/>
</odoo>

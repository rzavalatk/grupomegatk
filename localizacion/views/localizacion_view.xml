<odoo>
    <template id="assets_backend" inherit_id="web.assets_backend">
        <xpath expr="." position="inside">
            <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
            <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
        </xpath>
    </template>

    <record id="view_leaflet_map" model="ir.ui.view">
        <field name="name">leaflet.map.view</field>
        <field name="model">localizacion</field>
        <field name="arch" type="xml">
            <form string="Leaflet Map">
                <sheet>
                    <div class="oe_title">
                        <h1>Mapa con Leaflet</h1>
                    </div>
                    <div id="map" style="height: 400px; width: 100%;"></div>
                    <p id="coordinates"></p>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="menu_leaflet_map" name="Leaflet Map" action="action_leaflet_map"/>
    <record id="action_leaflet_map" model="ir.actions.act_window">
        <field name="name">Leaflet Map</field>
        <field name="res_model">localizacion</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_leaflet_map"/>
    </record>
</odoo>
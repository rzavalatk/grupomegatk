<odoo>
    <record id="view_gps_location_tree" model="ir.ui.view">
        <field name="name">gps.location.tree</field>
        <field name="model">gps.location</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="user_id"/>
                <field name="timestamp"/>
            </tree>
        </field>
    </record>
</odoo>
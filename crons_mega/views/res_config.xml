<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- Vista que agrega la sección "Cierre Diario" al panel general de ajustes -->
        <record id="res_config_settings_view_form_cierre_diario" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.cierre.diario</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="5"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('settings')]" position="inside">
                    <div class="app_settings_block" data-string="Cierre Diario" string="Cierre Diario" data-key="crons_mega">
                        <h2>Cierre Diario</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="journal_ids"/>
                                    <div class="text-muted">Diarios que se utilizarán en el cierre diario</div>
                                    <div class="text-muted">
                                        <field name="journal_ids" widget="many2many_tags" options="{'no_create_edit': True, 'no_create': True}"/>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="account_ids_cron_mega"/>
                                    <div class="text-muted">Cuentas CXC que se utilizarán en el cierre diario</div>
                                    <div class="text-muted">
                                        <field name="account_ids_cron_mega" widget="many2many_tags" options="{'no_create_edit': True, 'no_create': True}"/>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <label for="marca_ids"/>
                                    <div class="text-muted">Marcas para reporte semanal</div>
                                    <div class="text-muted">
                                        <field name="marca_ids" widget="many2many_tags" options="{'no_create_edit': True, 'no_create': True}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>

        <!-- Acción que abre ajustes filtrando directamente a la sección Cierre Diario -->
        <record id="action_cierre_diario_config" model="ir.actions.act_window">
            <field name="name">Cierre Diario</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_id" ref="res_config_settings_view_form_cierre_diario"/>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
            <field name="context">{'module': 'crons_mega'}</field>
        </record>

        <!-- Ítem en el menú Contabilidad > Configuración -->
        <menuitem id="menu_cierre_diario_config"
            name="Cierre Diario"
            parent="account.menu_finance_configuration"
            action="action_cierre_diario_config"
            sequence="100"/>

    </data>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="res_config_settings_view_form_cierre_diario" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.crons_mega</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="5"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Cierres diarios" string="Cierres diarios" data-key="crons_mega" groups="base.group_system">
                    <h2>Cierres diarios</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Diarios de cierre diario</span>
                                <div class="text-muted">
                                    Diarios que se utilizaran en el cierre diario
                                </div>
                                <div class="content-group">
                                    <div class="row mt16">
                                        <field name="journal_ids" widget="many2many_tags" options="{'no_create_edit': True, 'no_create': True}"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Cuentas CXC para cierre</span>
                                <div class="text-muted">
                                    Cuentas CXC que se utilizaran en el cierre diario
                                </div>
                                <div class="content-group">
                                    <div class="row mt16">
                                        <field name="account_ids_cron_mega" widget="many2many_tags" options="{'no_create_edit': True, 'no_create': True}"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Marcas para reporte semanal</span>
                                <div class="text-muted">
                                    Marcas usadas para generar el reporte semanal
                                </div>
                                <div class="content-group">
                                    <div class="row mt16">
                                        <field name="marca_ids" widget="many2many_tags" options="{'no_create_edit': True, 'no_create': True}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
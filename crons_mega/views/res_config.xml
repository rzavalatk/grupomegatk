<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_cierre_diario" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.prestamos</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="5"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='base_setup']" position="inside">
                    <block title="Rendimiento" id="crons_mega_performance">
                        <setting string="Diarios de cierre diario"
                                 help="Diarios que se utilizaran en el cierre diario.">
                            <field name="journal_ids" widget="many2many_tags" options="{'no_create_edit': True, 'no_create': True}"/>
                        </setting>

                        <setting string="Cuentas CXC para cierre"
                                 help="Cuentas CXC que se utilizaran en el cierre diario.">
                            <field name="account_ids_cron_mega" widget="many2many_tags" options="{'no_create_edit': True, 'no_create': True}"/>
                        </setting>

                        <setting string="Marcas para reporte semanal"
                                 help="Marcas usadas para generar el reporte semanal.">
                            <field name="marca_ids" widget="many2many_tags" options="{'no_create_edit': True, 'no_create': True}"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
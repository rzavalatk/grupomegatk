<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="crm_team_read_rule_account_user" model="ir.rule">
            <field name="name">CRM Team Read for Accounting Users</field>
            <field name="model_id" ref="sales_team.model_crm_team"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id','in', user.company_ids.ids)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
        </record>

        <record id="crm_team_read_rule_account_manager" model="ir.rule">
            <field name="name">CRM Team Read for Accounting Managers</field>
            <field name="model_id" ref="sales_team.model_crm_team"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id','in', user.company_ids.ids)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('account.group_account_manager'))]"/>
        </record>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="hoja_trabajo_print_view">
      <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
          <t t-call="fields_megatk.hoja_trabajo_print_view_soporte" t-lang="o.partner_id.lang"/>
        </t>
      </t>
    </template>

    <template id="hoja_trabajo_print_view_soporte">
      <t t-call="fields_megatk.external_layout_standard_soporte">
        <div class="page">
          <div class="text-center" style="font-family:'Arial'; font-size:30pt;">
            Hoja de Trabajo
          </div>
          <br/>
          <div style="float: right; margin-top: -30px;">
            <h4>Fecha Ingreso: <span t-field="o.create_date" t-field-options="{&quot;format&quot;: &quot;dd-MM-yyyy&quot;}"/></h4>
          </div>

          <table style="table-layout: fixed; width:100%;">
            <tr>
              <td colspan="2" style="vertical-align:middle; border: 1px solid black; font-family:'Arial'; font-size:22pt; text-align: center; background: rgb(13, 143, 210); ">
                Formulario de Visita
              </td>
            </tr>
            <tr>
              <td style="width:50%; vertical-align:top; border: 1px solid black; font-family:'Arial'; font-size:14pt; padding: 12px;">
                <p>&amp;nbsp;<b>Tipo de Soporte:</b> <span t-field="o.tipo_soporte"/></p>
                <p>&amp;nbsp;<b>Propósito Llamada:</b> <span t-if="o.proposito_llamada" t-esc="o.proposito_llamada"/></p>
                <p>&amp;nbsp;<b>Estado del Equipo:</b> <span t-field="o.estado_taller"/></p>
                <p>&amp;nbsp;<b>Tipo de Visita:</b>
                  <span t-if="o.tipo_visita" t-field="o.tipo_visita"/>
                  <span t-if="not o.tipo_visita and o.tipo_visita_sin_costo" t-field="o.tipo_visita_sin_costo"/>
                </p>
                <p>&amp;nbsp;<b>Propósito de la visita:</b> <span t-if="o.proposito" t-esc="o.proposito"/></p>
              </td>
              <td style="width:50%; vertical-align:top; border: 1px solid black; font-family:'Arial'; font-size:14pt; padding: 12px;">
                <p>&amp;nbsp;<b>La persona que reportó:</b> <span t-if="o.reporto" t-esc="o.reporto"/></p>
                <p>&amp;nbsp;<b>Teléfono:</b> <span t-if="o.repor_tel" t-esc="o.repor_tel"/></p>
                <p>&amp;nbsp;<b>Correo Electrónico:</b> <span t-if="o.repor_email" t-esc="o.repor_email"/></p>
                <p>&amp;nbsp;<b>Dirección de visita:</b> <span t-if="o.repor_direction" t-esc="o.repor_direction"/></p>
              </td>
            </tr>
          </table>
        </div>
      </t>
    </template>
  </data>
</odoo>

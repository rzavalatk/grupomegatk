<odoo>
    <record id="view_prestamo_form" model="ir.ui.view">
        <field name="name">prestamo.form</field>
        <field name="model">prestamo</field>
        <field name="arch" type="xml">
            <form string="Préstamo">
                <header>
                    <button name="generate_quota" type="object" string="Generar Cuotas" class="btn-primary" states="borrador"/>
                    <button name="unclick_quotas" type="object" string="Borrar Cuotas" class="btn-primary" states="generado"/>
                    <button string="Aprobar" type="object" name="action_approve" states="generado"/>
                    <button string="Rechazar" type="object" name="action_reject" states="aprobado"/>
                    <button string="Volver a borrador" type="object" name="go_to_draft" states="rechazado, cancelado"/>
                    <button string="Cancelar" type="object" name="action_cancel" states="aprobado"/>
                    <button string="Pagar" type="object" name="action_pay" states="aprobado"/>
                    <button string="Finalizar" type="object" name="ending" states="aprobado"/>
                    <field name="state" widget="statusbar" statusbar_visible="borrador, generado, aprobado, rechazado, cancelado, pagado"/>
				</header>
                <sheet>

                    <div class="oe_button_box" name="button_box">
							<button name="action_view_invoice" type="object" class="oe_stat_button" icon="fa-pencil-square-o" attrs="{'invisible': [('invoice_count_cxc', '=', 0)]}">
								<field name="invoice_count_cxc" widget="statinfo" string="Facturas"/>
							</button>
							<button name="action_view_payment" type="object" class="oe_stat_button" icon="fa-money" attrs="{'invisible': [('payment_count', '=', 0)]}">
								<field name="payment_count" widget="statinfo" string="Pagos cliente"/>
							</button>
							
						</div>

                    <group>
                        <h1>
                            <field name="name" attrs="{'readonly': True}"/>
                        </h1>
					</group>
                    <group name='prestamo' >
                        <group name="cliente" string='Datos del prestamo'>
                            <field name="partner_id"/>
                            <field name="loan_type"/>
                            <field name="amount_borrowed"/>
                            <field name="remaining_capital" />
                            <field name="pay_capital" />
                        </group>

                        <group name="fechas" string="Tiempo de prestamo">
                            <field name="meses_seleccion"/>
                            <field name="date_init"/>
                            <field name="date_ends" />
                            <field name="payment_frequency"/>
                        </group>
                        
                    </group>
                    <group name="contabilidad" string="Datos contables">
                        <field name="interest_rate"/>
                        <field name="currency_id" />
                        <field name="payment_term_id" />
                    </group>
                    <notebook>
                        <page name="cuotas" string="Cuotas">
                            <field name="quota_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="date_due"/>
                                    <field name="payment_date" />
                                    <field name="amount_capital" />
                                    <field name="amount_capital_quota" />
                                    <field name="interest_generated" />
                                    <field name="amount" />
                                    <field name="balance" />
                                    <field name="state" />
                                   
                                </tree>
                            </field>
                        </page>
                        <page name="cuentas" string="Cuentas">
                            <group >
                               <group name="info_encargado" string="Información">
                                    <field name="company_id" />
                                    <field name="user_id" />
                                </group>
                                <group name="info_cuentas" string="Cuentas">
                                    <field name="recibir_pagos" />
                                    <field name="account_id" />
                                    <field name="account_redes_id" />
                                </group> 
                            </group>
                            
                            
                            
                        </page>
                    </notebook>
                    
                    <footer>
                        <button name="export_excel" type="object" string="Exportar a Excel" class="btn-primary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_prestamo_tree" model="ir.ui.view">
        <field name="name">prestamo.tree</field>
        <field name="model">prestamo</field>
        <field name="arch" type="xml">
            <tree string="Préstamos">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount_borrowed"/>
                <field name="interest_rate"/>
                <field name="meses_seleccion"/>
                <field name="date_init"/>
                <field name="payment_frequency"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    
    <record id="action_prestamos" model="ir.actions.act_window">
        <field name="name">Préstamos</field>
        <field name="res_model">prestamo</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_prestamos_prestamos_action" name="Préstamos" parent="menu_prestamos_prestamos" action="action_prestamos"/>

    
</odoo>

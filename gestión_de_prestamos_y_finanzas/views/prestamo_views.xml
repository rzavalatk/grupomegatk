<odoo>
    <record id="view_prestamo_form" model="ir.ui.view">
        <field name="name">prestamo.form</field>
        <field name="model">prestamo</field>
        <field name="arch" type="xml">
            <form string="Préstamo">
                <header>
                    <button name="generate_quota" type="object" string="Generar Cuotas" class="btn-primary" states="borrador"/>
                    <button string="Aprobar" type="object" name="action_approve" states="borrador"/>
                    <button string="Rechazar" type="object" name="action_reject" states="borrador"/>
                    <button string="Pagar" type="object" name="action_pay" states="aprobado"/>
                    <!--<field name="state" widget="statusbar" nolabel="1"/>-->
				</header>
                <sheet>
                
                    <group>
                        <h1>
                            <field name="name" attrs="{'readonly': True}"/>
                        </h1>
					</group>
                    <group name='prestamo' >
                        <group name="cliente" string='Datos del prestamo'>
                            <field name="partner_id"/>
                            <field name="loan_type"/>
                            <field name="amount_borrowed"/>
                            
                            <field name="remaining_capital" />
                        </group>

                        <group name="fechas" string="Tiempo de prestamo">
                            <field name="duration"/>
                            <field name="date_init"/>
                            <field name="date_end" />
                            <field name="payment_frequency"/>
                        </group>
                        
                    </group>
                    <group name="contabilidad" string="Datos contables">
                        <field name="payment_term_id" />
                        <field name="meses_cred" />
                        <field name="interest_rate"/>
                        <field name="currency_id" />
                    </group>
                    <notebook>
                        <page name="cuotas" string="Cuotas">
                            <field name="quota_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="date_due"/>
                                    <field name="payment_date" />
                                    <field name="amount_capital" />
                                    <field name="amount_capital_quota" />
                                    <field name="interest_generated" />
                                    <field name="amount" />
                                    <field name="balance" />
                                    <field name="state" />
                                   
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <!--<group string="Cuotas">
                        <field name="cuota_ids">
                            <tree string="Cuotas">
                                <field name="monto"/>
                                <field name="fecha_vencimiento"/>
                                <field name="pagado"/>
                            </tree>
                        </field>
                    </group>
                    <group string="Garantías">
                        <field name="garantia_ids">
                            <tree string="Garantías">
                                <field name="descripcion"/>
                                <field name="valor"/>
                            </tree>
                        </field>
                    </group>-->
                    <footer>
                        <button name="export_excel" type="object" string="Exportar a Excel" class="btn-primary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_prestamo_tree" model="ir.ui.view">
        <field name="name">prestamo.tree</field>
        <field name="model">prestamo</field>
        <field name="arch" type="xml">
            <tree string="Préstamos">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount_borrowed"/>
                <field name="interest_rate"/>
                <field name="duration"/>
                <field name="date_init"/>
                <field name="payment_frequency"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    
    <record id="action_prestamos" model="ir.actions.act_window">
        <field name="name">Préstamos</field>
        <field name="res_model">prestamo</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_prestamos_prestamos_action" name="Préstamos" parent="menu_prestamos_prestamos" action="action_prestamos"/>

    
</odoo>

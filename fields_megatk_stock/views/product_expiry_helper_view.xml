<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_expiry_helper_form_view" model="ir.ui.view">
        <field name="name">product.template.expiry.helper.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='use_expiration_date']" position="after">
              <field name="lot_reference_id"
                                    domain="[('id', 'in', valid_lot_ids)]"
                  options="{'no_create': True, 'no_open': False}"
                  invisible="tracking == 'none' or not use_expiration_date"
                  help="Lote usado como referencia para cargar su fecha de caducidad."/>
              <field name="expiration_date_helper"
                  readonly="1"
                  invisible="tracking == 'none' or not use_expiration_date"/>
            </xpath>
        </field>
    </record>

    <record id="product_product_expiry_helper_form_view" model="ir.ui.view">
        <field name="name">product.product.expiry.helper.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='use_expiration_date']" position="after">
                <field name="lot_reference_id"
                       domain="[('id', 'in', valid_lot_ids)]"
                       options="{'no_create': True, 'no_open': False}"
                       invisible="tracking == 'none' or not use_expiration_date"
                       help="Lote usado como referencia para cargar su fecha de caducidad."/>
                <field name="expiration_date_helper"
                       readonly="1"
                       invisible="tracking == 'none' or not use_expiration_date"/>
            </xpath>
        </field>
    </record>
</odoo>
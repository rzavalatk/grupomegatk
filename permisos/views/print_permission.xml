<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Plantilla del reporte -->
    <template id="report_hr_employee_permission_view_new">
        <t t-call="web.html_container">
          <t t-foreach="docs" t-as="doc">
            <t t-set="lang" t-value="doc.partner_id.lang"/>
            <t t-call="permisos.report_hr_employee_permission" t-lang="lang"/>
          </t>
        </t>
    </template>

    <template id="report_hr_employee_permission" name="Formulario de Permiso">
        <t t-call="web.basic_layout">
            <t t-set="o" t-value="docs[0]"/>
            <main>
                <div style="font-family: calibri; font-size: 14px; margin: 0 1cm; padding: 0;">
                    <!-- Encabezado simplificado -->
                    <div style="text-align: center; margin-bottom: 15px;">
                        <h1 style="font-size: 16px; margin: 5px 0; text-transform: uppercase;">ÁREA DE RECURSOS HUMANOS</h1>
                        <h2 style="font-size: 14px; margin: 5px 0; text-transform: uppercase;">AUSENCIAS DE PERSONAL</h2>
                    </div>
                    
                   
                       
                    
                    <!-- Información del empleado -->
                    <table style="width: 100%; margin-bottom: 10px;">
                        <tr>
                            <h4 style="font-size: 13px; margin: 0px 0;"><strong> A LA GERENCIA DE RECURSOS HUMANOS INFORMO: </strong></h4>
                            <td style="width: 50%; margin-top: 5px 0;">
                                Que el día <span t-field="o.fecha_inicio" t-field-options='{"format": "dd/MM/yyyy HH:mm:ss"}'/>
                                        el Sr. (Sra. Srita) <span t-field="o.employe_id.name"/>
                            
                                <br/> quien se desempeña como:  <span t-field="o.employe_id.job_id.name"/> 
                                en el area de <span t-field="o.employe_id.department_id.name"/>
                                <div style="margin-bottom: 10px;">
                                    <p style="margin: 5px 0; text-align: center;">No se presentó a laborar en la(s) siguiente(s) fecha(s):</p>
                                    <p style="margin: 5px 0;">
                                        <span t-field="o.fecha_inicio" t-field-options='{"format": "dd/MM/yyyy HH:mm:ss"}'/>
                                        <span t-if="o.fecha_fin and o.fecha_fin != o.fecha_inicio"> - 
                                            <span t-field="o.fecha_fin" t-field-options='{"format": "dd/MM/yyyy HH:mm:ss"}'/>
                                        </span>
                                    </p>
                                </div>
                            </td>
                            <!-- Fechas de ausencia -->
                    
                        </tr>
                    </table>
    
                    
    
                    <!-- Opciones de cargo - Tabla más compacta -->
                    <div style="margin-bottom: 10px;">
                        <p style="margin: 5px 0; text-align: center;">Por tanto, autorizo para aplicar lo siguiente:</p>
                        <table style="width: 100%; margin: 5px 0; border-collapse: collapse;">
                            <tr>
                                <td style="border: 1px solid #000; padding: 5px 5px 5px 25px; width: 50%; position: relative;">
                                    <span t-if="o.cargo == 'vacaciones'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                    CARGAR A VACACIONES
                                </td>
                                <td style="border: 1px solid #000; padding: 5px 5px 5px 25px; width: 50%; position: relative;">
                                    <span t-if="o.cargo == 'deducir'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                    DEDUCIR DEL SUELDO
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #000; padding: 5px 5px 5px 25px; width: 50%; position: relative;">
                                    <span t-if="o.cargo == 'permiso'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                    PERMISO SIN NINGÚN CARGO
                                </td>
                                <td style="border: 1px solid #000; padding: 5px 5px 5px 25px; width: 50%; position: relative;">
                                    <span t-if="o.cargo == 'incapacidad'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                    ADJUNTO INCAPACIDAD
                                </td>
                            </tr>
                            <td style="width: 50%; margin-top: 5px 0;"> JUSTIFICACIÓN DE LA ACCION: </td>
                        </table>
                    </div>
    
                    <!-- Secciones restantes con formato similar al PDF de referencia -->
                    <!-- ... (mantener el mismo formato para las otras secciones) ... -->
    
                    <!-- Firmas alineadas correctamente -->
                    
                        <tr>
                            <td style="width: 50%;">
                                <p style="margin: 5px 0;">LUGAR Y FECHA <span t-field="o.create_date" t-field-options='{"format": "dd/MM/yyyy HH:mm:ss"}'/></p>
                                <p style="margin: 5px 0;"></p>
                            </td>
                            
                        </tr>
                        <table style="width: 100%; margin-top: 30px;">
                        <tr>
                            <td style="width: 50%; text-align: center; padding-top: 10px;">
                                <p style="margin: 5px 0;">NOMBRE JEFE INMEDIATO</p>
                                <p style="margin: 5px 0;"><span t-field="o.employe_id.parent_id.name"/></p>
                            </td>
                            <td style="width: 50%; text-align: center; padding-top: 10px;">
                                <p style="margin: 5px 0;">NOMBRE EMPLEADO</p>
                                <p style="margin: 5px 0;"><span t-field="o.employe_id.name"/></p>
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 50%; text-align: center; padding-top: 10px; ">
                                <p style="margin: 5px 0;">FIRMA JEFE INMEDIATO</p>
                                <div style="margin: 5px auto; border-top: 1px solid #000; width: 80%; text-align: center; margin-botton: 10px;"></div>
                            </td>
                            <td style="width: 50%; text-align: center; padding-top: 10px; margin-botton: 10px;">
                                <p style="margin: 5px 0;">FIRMA EMPLEADO</p>
                                <div style="margin: 5px auto; border-top: 1px solid #000; width: 80%; text-slign: center; margin-botton: 10px;"></div>
                            </td>
                        </tr>
                    </table>
                </div>
            </main>
        </t>
    </template>

   
    <record id="paperformat_permiso" model="report.paperformat">
        <field name="name">Formato Permiso</field>
        <field name="format">A4</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_spacing">0</field>
    </record>

<!-- Luego modifica tu record para usar este formato -->
<record id="action_report_hr_employee_permission" model="ir.actions.report">
    <!-- otros campos -->
    <field name="paperformat_id" ref="paperformat_permiso"/>
</record>

    <record id="action_report_hr_employee_permission" model="ir.actions.report">
        <field name="name">Formulario de Permiso</field>
        <field name="model">hr.employee.permisos</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">permisos.report_hr_employee_permission</field>
        <field name="report_file">permisos.report_hr_employee_permission</field>
        <field name="binding_model_id" ref="model_hr_employee_permisos"/>
        <field name="print_report_name">'formulario_permiso_%s' % (object.name or '')</field>
        <field name="paperformat_id" ref="paperformat_permiso"/>
    </record>
</odoo>
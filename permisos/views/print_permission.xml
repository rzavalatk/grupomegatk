<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Plantilla del reporte -->
    <template id="report_hr_employee_permission_view_new">
        <t t-call="web.html_container">
          <t t-foreach="docs" t-as="doc">
            <t t-set="lang" t-value="doc.partner_id.lang"/>
            <t t-call="permisos.report_hr_employee_permission" t-lang="lang"/>
          </t>
        </t>
    </template>

    <template id="report_hr_employee_permission" name="Formulario de Permiso">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="docs[0]"/>
            <div class="page" style="font-family: Arial; font-size: 11px; margin: 0; padding: 0;">
                <!-- Encabezado -->
                <div style="text-align: center; margin-bottom: 10px;">
                    <h1>ÁREA DE RECURSOS HUMANOS</h1>
                    <h2>AUSENCIAS DE PERSONAL</h2>
                    <h3>A LA GERENCIA DE RECURSOS HUMANOS INFORMO:</h3>
                </div>
                
                <!-- Información del empleado -->
                <table style="margin-bottom: 10px;">
                    <tr>
                        <td style="width: 50%;">
                            Que el día <span t-field="o.fecha_inicio" t-field-options='{"format": "dd/MM/yyyy HH:mm:ss"}'/>
                        </td>
                        <td style="width: 50%;">
                            el Sr. (Sra. Srita) <span t-field="o.employe_id.name"/>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2">
                            quien se desempeña como: <span t-field="o.employe_id.job_id.name"/> 
                            en el area de <span t-field="o.employe_id.department_id.name"/>
                        </td>
                    </tr>
                </table>

                <!-- Fechas de ausencia -->
                <div style="margin-bottom: 10px;">
                    <p>No se presentó a laborar en la(s) siguiente(s) fecha(s):</p>
                    <p>
                        <span t-field="o.fecha_inicio" t-field-options='{"format": "dd-MM-yyyy HH:mm:ss"}'/>
                        <span t-if="o.fecha_fin and o.fecha_fin != o.fecha_inicio"> - 
                            <span t-field="o.fecha_fin" t-field-options='{"format": "dd-MM-yyyy HH:mm:ss"}'/>
                        </span>
                    </p>
                </div>

                <!-- Opciones de cargo -->
                <div style="margin-bottom: 10px;">
                    <p>Por tanto, autorizo para aplicar lo siguiente:</p>
                    <table style="margin: 5px 0;">
                        <tr>
                            <td style="border: 1px solid #000; padding: 3px 3px 3px 20px; width: 50%; position: relative;">
                                <span t-if="o.cargo == 'vacaciones'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                CARGAR A VACACIONES
                            </td>
                            <td style="border: 1px solid #000; padding: 3px 3px 3px 20px; width: 50%; position: relative;">
                                <span t-if="o.cargo == 'deducir'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                DEDUCIR DEL SUELDO
                            </td>
                        </tr>
                        <tr>
                            <td style="border: 1px solid #000; padding: 3px 3px 3px 20px; width: 50%; position: relative;">
                                <span t-if="o.cargo == 'permiso'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                PERMISO SIN NINGÚN CARGO
                            </td>
                            <td style="border: 1px solid #000; padding: 3px 3px 3px 20px; width: 50%; position: relative;">
                                <span t-if="o.cargo == 'incapacidad'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                ADJUNTO INCAPACIDAD
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- Justificación -->
                <div style="margin-bottom: 10px;">
                    <p>JUSTIFICACION DE LA ACCION:</p>
                    <div style="border-bottom: 1px solid #000; min-height: 18px; padding: 0 5px;">
                        <span t-field="o.justificacion"/>
                    </div>
                </div>

                <!-- Empleado cubierto -->
                <div style="margin-bottom: 10px;">
                    <p>LA AUSENCIA DE EL (LA) EMPLEADO (A) FUE CUBIERTA POR:</p>
                    <p>SR. (SRITA.) <span t-field="o.cubierto_employe_id.name" t-esc="o.cubierto_employe_id.name or 'NADIE'"/></p>
                </div>

                <!-- Reporte de ausencia -->
                <div style="margin-bottom: 15px;">
                    <p>EL EMPLEADO REPORTO SU AUSENCIA:</p>
                    <table style="margin: 5px 0;">
                        <tr>
                            <td style="border: 1px solid #000; padding: 3px 3px 3px 20px; width: 50%; position: relative;">
                                <span t-if="o.reporto == 'anticipacion'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                CON ANTICIPACIÓN
                            </td>
                            <td style="border: 1px solid #000; padding: 3px 3px 3px 20px; width: 50%; position: relative;">
                                <span t-if="o.reporto == 'telefono'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                LLAMÓ POR TELÉFONO
                            </td>
                        </tr>
                        <tr>
                            <td style="border: 1px solid #000; padding: 3px 3px 3px 20px; width: 50%; position: relative;">
                                <span t-if="o.reporto == 'mensaje'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                ENVIÓ MENSAJE
                            </td>
                            <td style="border: 1px solid #000; padding: 3px 3px 3px 20px; width: 50%; position: relative;">
                                <span t-if="o.reporto == 'otro'" style="position: absolute; left: 5px; top: 50%; transform: translateY(-50%);">✓</span>
                                OTRO
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- Envío de llaves -->
                <div style="margin-bottom: 15px;">
                    <p>ENVÍO: Llaves de Escritorio, de Archivo: SI / NO</p>
                </div>

                <!-- Firmas -->
                <table style="margin-top: 30px; page-break-inside: avoid;">
                    <tr>
                        <td style="width: 50%;">
                            <p>LUGAR Y FECHA</p>
                            <p><span t-field="o.create_date" t-field-options='{"format": "dd/MM/yyyy HH:mm:ss"}'/></p>
                        </td>
                        <td style="width: 50%; text-align: right;">
                            <p>NOMBRE JEFE INMEDIATO</p>
                            <p><span t-field="o.employe_id.parent_id.name"/></p>
                            <div style="border-top: 1px solid #000; width: 80%; margin-top: 20px; margin-left: auto;"></div>
                            <p style="margin-top: 5px;">FIRMA JEFE INMEDIATO</p>
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 50%;">
                            <div style="border-top: 1px solid #000; width: 80%; margin-top: 20px;"></div>
                        </td>
                        <td style="width: 50%; text-align: right;">
                            <p>NOMBRE EMPLEADO</p>
                            <p><span t-field="o.employe_id.name"/></p>
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 50%;"></td>
                        <td style="width: 50%; text-align: right;">
                            <div style="border-top: 1px solid #000; width: 80%; margin-top: 20px; margin-left: auto;"></div>
                            <p style="margin-top: 5px;">FIRMA EMPLEADO</p>
                        </td>
                    </tr>
                </table>
            </div>
        </t>
    </template>

   
<record id="paperformat_permiso" model="report.paperformat">
    <field name="name">Formato Permiso</field>
    <field name="default" eval="True"/>
    <field name="format">A4</field>
    <field name="page_height">0</field>
    <field name="page_width">0</field>
    <field name="orientation">Portrait</field>
    <field name="margin_top">10</field>
    <field name="margin_bottom">10</field>
    <field name="margin_left">10</field>
    <field name="margin_right">10</field>
    <field name="header_line" eval="False"/>
    <field name="header_spacing">0</field>
    <field name="dpi">90</field>
</record>

<!-- Luego modifica tu record para usar este formato -->
<record id="action_report_hr_employee_permission" model="ir.actions.report">
    <!-- otros campos -->
    <field name="paperformat_id" ref="paperformat_permiso"/>
</record>

    <record id="action_report_hr_employee_permission" model="ir.actions.report">
        <field name="name">Formulario de Permiso</field>
        <field name="model">hr.employee.permisos</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">permisos.report_hr_employee_permission</field>
        <field name="report_file">permisos.report_hr_employee_permission</field>
        <field name="binding_model_id" ref="model_hr_employee_permisos"/>
        <field name="print_report_name">'formulario_permiso_%s' % (object.name or '')</field>
        <field name="paperformat_id" ref="paperformat_permiso"/>
    </record>
</odoo>
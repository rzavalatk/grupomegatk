<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_hr_employee_permission_view">
      <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
          <t t-if="doc"> 
            <t t-set="lang" t-value="doc.employee_id.user_id.lang or doc.company_id.partner_id.lang or 'es_ES'"/> 
            <t t-call="permisos.report_hr_employee_permission_document" t-lang="lang"/>
          </t>
        </t>
      </t>
    </template>

    <template id="report_hr_employee_permission_document" name="Formulario de Permiso Document">
        <t t-call="web.report_layout">
            <div class="page" style="font-family: 'Arial', sans-serif; font-size: 11pt;">

                <div class="header" style="text-align: center; margin-bottom: 30px;">
                    <h4 style="margin-bottom: 5px; font-weight: bold;">AREA DE RECURSOS HUMANOS</h4>
                    <h5 style="margin-bottom: 10px; font-weight: bold;">AUSENCIAS DE PERSONAL</h5>
                    <p style="margin-bottom: 20px; text-align: left;">A la Gerencia de Recursos Humanos informo:</p>
                </div>

                <table class="info-table" style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                    <tr>
                        <td style="width: 50%; padding: 5px;">Que el día <span t-field="doc.fecha_inicio" t-options='{"format": "d"}'/> de <span t-field="doc.fecha_inicio" t-options='{"format": "MMMM"}'/> <span t-field="doc.fecha_inicio" t-options='{"format": "YYYY"}'/></td>
                        <td style="width: 50%; padding: 5px;">el Sr. (Sra. Srita) <span t-field="doc.employe_id.name" style="font-weight: bold;"/></td>
                    </tr>
                    <tr>
                        <td colspan="2" style="padding: 5px;">quien se desempeña como: <span t-field="doc.employe_id.job_id.name" style="font-weight: bold;"/> en el area de <span t-field="doc.employe_id.department_id.name" style="font-weight: bold;"/></td>
                    </tr>
                </table>

                <div style="margin-bottom: 20px;">
                    <p>No se presentó a laborar en la(s) siguiente(s) fecha(s):</p>
                    <p style="border-bottom: 1px solid black; padding-bottom: 5px; min-height: 20px;">
                        <span t-field="doc.fecha_inicio_txt"/>
                        <span t-if="doc.fecha_fin and doc.fecha_fin != doc.fecha_inicio"> - <span t-field="doc.fecha_fin_txt"/></span>
                    </p>
                </div>

                <div style="margin-bottom: 20px;">
                    <p>Por tanto, autorizo para aplicar lo siguiente:</p>
                    <style>
                        .options-table td { border: 1px solid black; padding: 8px; }
                        .options-table .checkmark { font-weight: bold; margin-right: 5px; }
                        .options-table .selected { background-color: #eee; } /* Optional: highlight selected */
                    </style>
                    <table class="options-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                        <tr>
                            <td t-attf-class="#{'selected' if doc.cargo == 'vacaciones' else ''}" style="width: 50%;">
                                <span class="checkmark" t-if="doc.cargo == 'vacaciones'">&#x2713;</span> <span t-else="">&#x2610;</span> CARGAR A VACACIONES
                            </td>
                            <td t-attf-class="#{'selected' if doc.cargo == 'deducir' else ''}" style="width: 50%;">
                                <span class="checkmark" t-if="doc.cargo == 'deducir'">&#x2713;</span>
                                <span t-else="">&#x2610;</span>
                                DEDUCIR DEL SUELDO
                            </td>
                        </tr>
                        <tr>
                            <td t-attf-class="#{'selected' if doc.cargo == 'permiso' else ''}">
                                <span class="checkmark" t-if="doc.cargo == 'permiso'">&#x2713;</span>
                                <span t-else="">&#x2610;</span>
                                PERMISO SIN NINGÚN CARGO
                            </td>
                            <td t-attf-class="#{'selected' if doc.cargo == 'incapacidad' else ''}">
                                <span class="checkmark" t-if="doc.cargo == 'incapacidad'">&#x2713;</span>
                                <span t-else="">&#x2610;</span>
                                ADJUNTO INCAPACIDAD
                            </td>
                        </tr>
                    </table>
                </div>

                <div style="margin-bottom: 20px;">
                    <p>JUSTIFICACION DE LA ACCION:</p>
                    <div style="border-bottom: 1px solid black; min-height: 25px; padding: 5px;">
                        <span t-field="doc.justificacion"/>
                    </div>
                </div>

                <div style="margin-bottom: 20px;">
                    <p>LA AUSENCIA DE EL (LA) EMPLEADO (A) FUE CUBIERTA POR:</p>
                     <p style="border-bottom: 1px solid black; min-height: 25px; padding: 5px;">
                       SR. (SRITA.) <span t-esc="doc.cubierto_employe_id.name if doc.cubierto_employe_id else '_________________________'"/> O POR NADIE
                    </p>
                </div>

                <div style="margin-bottom: 20px;">
                    <p>EL EMPLEADO REPORTO SU AUSENCIA:</p>
                     <style>
                        .report-options-table td { border: 1px solid black; padding: 8px; }
                        .report-options-table .checkmark { font-weight: bold; margin-right: 5px;}
                        .report-options-table .selected { background-color: #eee; } /* Optional: highlight selected */
                    </style>
                    <table class="report-options-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                        <tr>
                            <td t-attf-class="#{'selected' if doc.reporto == 'anticipacion' else ''}" style="width: 50%;">
                                <span class="checkmark" t-if="doc.reporto == 'anticipacion'">&#x2713;</span>
                                <span t-else="">&#x2610;</span>
                                CON ANTICIPACIÓN
                            </td>
                            <td t-attf-class="#{'selected' if doc.reporto == 'telefono' else ''}" style="width: 50%;">
                                <span class="checkmark" t-if="doc.reporto == 'telefono'">&#x2713;</span>
                                 <span t-else="">&#x2610;</span>
                                LLAMÓ POR TELÉFONO
                            </td>
                        </tr>
                        <tr>
                            <td t-attf-class="#{'selected' if doc.reporto == 'mensaje' else ''}">
                                <span class="checkmark" t-if="doc.reporto == 'mensaje'">&#x2713;</span>
                                 <span t-else="">&#x2610;</span>
                                ENVIÓ MENSAJE
                            </td>
                            <td t-attf-class="#{'selected' if doc.reporto == 'otro' else ''}">
                                <span class="checkmark" t-if="doc.reporto == 'otro'">&#x2713;</span>
                                 <span t-else="">&#x2610;</span>
                                OTRO
                            </td>
                        </tr>
                    </table>
                </div>

                <div style="margin-bottom: 40px;">
                    <p>ENVÍO: Llaves de Escritorio, de Archivo: SI / NO</p> 
                </div>

                <table class="signature-table" style="width: 100%; border-collapse: collapse; margin-top: 30px;">
                     <tr>
                        <td style="width: 50%; padding: 5px; vertical-align: bottom;">
                            <p style="margin-bottom: 5px;">LUGAR Y FECHA</p>
                            <p style="border-bottom: 1px solid black; min-height: 20px;"><span t-field="doc.create_date" t-options='{"format": "dd/MM/yyyy"}'/></p>
                        </td>
                        <td style="width: 50%; padding: 5px; vertical-align: bottom; text-align: center;">
                             <p style="margin-bottom: 40px;">&amp;nbsp;</p> <div style="border-top: 1px solid black; padding-top: 5px;">
                                NOMBRE JEFE INMEDIATO <br/>(<span t-esc="doc.employe_id.parent_id.name if doc.employe_id and doc.employe_id.parent_id else ''"/>)
                            </div>
                        </td>
                    </tr>
                     <tr>
                        <td style="width: 50%; padding: 5px; vertical-align: bottom; text-align: center;">
                            <p style="margin-bottom: 40px;">&amp;nbsp;</p> <div style="border-top: 1px solid black; padding-top: 5px;">
                                FIRMA JEFE INMEDIATO
                            </div>
                        </td>
                         <td style="width: 50%; padding: 5px; vertical-align: bottom; text-align: center;">
                             <p style="margin-bottom: 40px;">&amp;nbsp;</p> <div style="border-top: 1px solid black; padding-top: 5px;">
                                NOMBRE EMPLEADO <br/>(<span t-esc="doc.employe_id.name if doc.employe_id else ''"/>)
                            </div>
                        </td>
                    </tr>
                     <tr>
                        <td></td>
                        <td style="width: 50%; padding: 5px; vertical-align: bottom; text-align: center;">
                           <p style="margin-bottom: 40px;">&amp;nbsp;</p> <div style="border-top: 1px solid black; padding-top: 5px;">FIRMA EMPLEADO</div>
                        </td>
                    </tr>
                </table> 
            </div>
        </t>
    </template>

    <record id="action_report_hr_employee_permission" model="ir.actions.report">
        <field name="name">Formulario de Permiso</field>
        <field name="model">hr.employee.permisos</field> <field name="report_type">qweb-pdf</field>
        <field name="report_name">permisos.report_hr_employee_permission_document</field> 
        <field name="report_file">permisos.report_hr_employee_permission_document</field> 
        <field name="binding_model_id" ref="model_hr_employee_permisos"/> 
        <field name="paperformat_id" eval="False"/> 
    </record>

</odoo>
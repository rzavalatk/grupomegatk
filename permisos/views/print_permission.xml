<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="report_hr_employee_permission" name="Formulario de Permiso">
        <t t-call="web.report_layout">
            <style>
                body {
                    font-family: Arial, sans-serif;
                    font-size: 12px;
                    margin: 1.5cm;
                }
                .header {
                    text-align: center;
                    margin-bottom: 20px;
                }
                .header h1 {
                    font-size: 16px;
                    margin-bottom: 5px;
                    text-transform: uppercase;
                }
                .header h2, .header h3 {
                    font-size: 14px;
                    margin: 5px 0;
                    text-transform: uppercase;
                }
                .info-table {
                    margin-top: -25px;
                    width: 100%;
                    margin: 10px 0;
                    border-collapse: collapse;
                }
                .info-table td {
                    padding: 5px;
                    vertical-align: top;
                }
                .options-table {
                    width: 100%;
                    margin: 15px 0;
                    border-collapse: collapse;
                }
                .options-table td {
                    border: 1px solid #000;
                    padding: 8px;
                    text-align: left;
                    position: relative;
                    padding-left: 25px;
                }
                .checkmark {
                    position: absolute;
                    left: 5px;
                    top: 50%;
                    transform: translateY(-50%);
                    font-size: 16px;
                }
                .underline {
                    border-bottom: 1px solid #000;
                    min-height: 20px;
                    padding: 0 5px;
                    width: 100%;
                    display: block;
                }
                .signature-table {
                    width: 100%;
                    margin-top: 40px;
                }
                .signature-table td {
                    padding: 5px;
                    vertical-align: top;
                }
                .signature-line {
                    border-top: 1px solid #000;
                    width: 80%;
                    margin-top: 25px;
                }
                .selected {
                    background-color: #f0f0f0;
                }
            </style>
            
            <t t-foreach="docs" t-as="o">
                <div class="header">
                    <h1>AREA DE RECURSOS HUMANOS</h1>
                    <h2>AUSENCIAS DE PERSONAL</h2>
                    <h3>A la Gerencia de Recursos Humanos informo:</h3>
                </div>

                <table class="info-table">
                    <tr>
                        <td style="width: 50%;">Que el día <span t-field="o.fecha_inicio" t-field-options='{"format": "d"}'/> de <span t-field="o.fecha_inicio" t-field-options='{"format": "MMMM"}'/> <span t-field="o.fecha_inicio" t-field-options='{"format": "YYYY"}'/></td>
                        <td style="width: 50%;">el Sr. (Sra. Srita) <span t-field="o.employe_id.name"/></td>
                    </tr>
                    <tr>
                        <td colspan="2">quien se desempeña como: <span t-field="o.employe_id.job_id.name"/> en el area de <span t-field="o.employe_id.department_id.name"/></td>
                    </tr>
                </table>

                <div style="margin-bottom: 20px;">
                    <p>No se presentó a laborar en la(s) siguiente(s) fecha(s):</p>
                    <p>
                        <span t-field="o.fecha_inicio_txt"/>
                        <span t-if="o.fecha_fin and o.fecha_fin != o.fecha_inicio"> - <span t-field="o.fecha_fin_txt"/></span>
                    </p>
                </div>

                <div style="margin-bottom: 20px;">
                    <p>Por tanto, autorizo para aplicar lo siguiente:</p>
                    <table class="options-table">
                        <tr>
                            <td t-attf-class="#{'selected' if o.cargo == 'vacaciones' else ''}">
                                <span class="checkmark" t-if="o.cargo == 'vacaciones'">✓</span>
                                CARGAR A VACACIONES
                            </td>
                            <td t-attf-class="#{'selected' if o.cargo == 'deducir' else ''}">
                                <span class="checkmark" t-if="o.cargo == 'deducir'">✓</span>
                                DEDUCIR DEL SUELDO
                            </td>
                        </tr>
                        <tr>
                            <td t-attf-class="#{'selected' if o.cargo == 'permiso' else ''}">
                                <span class="checkmark" t-if="o.cargo == 'permiso'">✓</span>
                                PERMISO SIN NINGÚN CARGO
                            </td>
                            <td t-attf-class="#{'selected' if o.cargo == 'incapacidad' else ''}">
                                <span class="checkmark" t-if="o.cargo == 'incapacidad'">✓</span>
                                ADJUNTO INCAPACIDAD
                            </td>
                        </tr>
                    </table>
                </div>

                <div style="margin-bottom: 20px;">
                    <p>JUSTIFICACION DE LA ACCION:</p>
                    <span class="underline"><span t-field="o.justificacion"/></span>
                </div>

                <div style="margin-bottom: 20px;">
                    <p>LA AUSENCIA DE EL (LA) EMPLEADO (A) FUE CUBIERTA POR:</p>
                    <p>
                        SR. (SRITA.) <span t-field="o.cubierto_employe_id.name" t-esc="o.cubierto_employe_id.name or 'NADIE'"/>
                    </p>
                </div>

                <div style="margin-bottom: 20px;">
                    <p>EL EMPLEADO REPORTO SU AUSENCIA:</p>
                    <table class="options-table">
                        <tr>
                            <td t-attf-class="#{'selected' if o.reporto == 'anticipacion' else ''}">
                                <span class="checkmark" t-if="o.reporto == 'anticipacion'">✓</span>
                                CON ANTICIPACIÓN
                            </td>
                            <td t-attf-class="#{'selected' if o.reporto == 'telefono' else ''}">
                                <span class="checkmark" t-if="o.reporto == 'telefono'">✓</span>
                                LLAMÓ POR TELÉFONO
                            </td>
                        </tr>
                        <tr>
                            <td t-attf-class="#{'selected' if o.reporto == 'mensaje' else ''}">
                                <span class="checkmark" t-if="o.reporto == 'mensaje'">✓</span>
                                ENVIÓ MENSAJE
                            </td>
                            <td t-attf-class="#{'selected' if o.reporto == 'otro' else ''}">
                                <span class="checkmark" t-if="o.reporto == 'otro'">✓</span>
                                OTRO
                            </td>
                        </tr>
                    </table>
                </div>

                <div style="margin-bottom: 20px;">
                    <p>ENVÍO: Llaves de Escritorio, de Archivo: SI / NO</p>
                </div>

                <table class="signature-table">
                    <tr>
                        <td style="width: 50%;">
                            <p>LUGAR Y FECHA</p>
                            <p><span t-field="o.create_date" t-field-options='{"format": "dd/MM/yyyy"}'/></p>
                        </td>
                        <td style="width: 50%; text-align: right;">
                            <p>NOMBRE JEFE INMEDIATO</p>
                            <p><span t-field="o.employe_id.parent_id.name"/></p>
                            <div class="signature-line"></div>
                        </td>
                    </tr>
                    <tr>
                        <td style="width: 50%;">
                            <p>FIRMA JEFE INMEDIATO</p>
                            <div class="signature-line"></div>
                        </td>
                        <td style="width: 50%; text-align: right;">
                            <p>NOMBRE EMPLEADO</p>
                            <p><span t-field="o.employe_id.name"/></p>
                        </td>
                    </tr>
                    <tr>
                        <td></td>
                        <td style="text-align: right;">
                            <p>FIRMA EMPLEADO</p>
                            <div class="signature-line"></div>
                        </td>
                    </tr>
                </table>
            </t>
        </t>
    </template>
<record id="action_report_hr_employee_permission" model="ir.actions.report">
    <field name="name">Formulario de Permiso</field>
    <field name="model">hr.employee.permisos</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">permisos.report_hr_employee_permission</field>
    <field name="report_file">permisos.report_hr_employee_permission</field>
    <field name="binding_model_id" ref="model_hr_employee_permisos"/>
</record>



</odoo>

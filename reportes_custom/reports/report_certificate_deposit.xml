<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Plantilla del reporte -->
    <template id="report_certificate_deposit_template_view">
      <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
          <t t-call="reportes_custom.report_certificate_deposit_template" t-lang="doc.partner_id.lang"/>
        </t>
      </t>
    </template>

    <template id="report_certificate_deposit_template">
        
            <div class="page" style="border-width: 2; border-style: solid;">
                
                <!-- Encabezado -->
                <div class="Encabezado" style="display: flex; flex-direction: row; flex-grow: 1fr 2fr 1fr; ">
                    <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)" style="max-height: 270px; position: absolute; top: -110px; padding-top: 0px; padding: 0px;" alt="Logo"/>
                    
                    <h2 style="position: absolute; top: 50px; left: 80px">CERTIFICADO DE DEPOSITO A PLAZO FIJO</h2>        
                    
                    <p>No: <span t-field="doc.internal_number"/></p>
                </div>
                

                <!-- Fecha y Lugar -->
                <div class="row mt-3">
                    <div class="col-6">
                        <p>Lugar y Fecha: <span t-field="doc.company_id.city"/>, <span t-field="doc.invoice_date"/></p>
                    </div>
                </div>

                <!-- Datos de depósito -->
                <div class="row">
                    <div class="col-12">
                        <p>Por el presente Certificamos que en esta fecha hemos recibido de: <strong t-field="doc.partner_id.name"/></p>
                        <p>La cantidad de: <strong t-field="doc.amount_total"/> Lps</p>
                        <p>En calidad de depósito a la vista.</p>
                    </div>
                </div>

                <!-- Firma y sello -->
                <div class="row mt-5">
                    <div class="col-6 text-left">
                        <p>Firma Autorizada: ___________________________</p>
                    </div>
                    <div class="col-6 text-right">
                        <p>Sello: ___________________________</p>
                    </div>
                </div>
            </div>
        
    </template>

    
</odoo>
